module aio::config {    
    use 0x2::object;    
    use 0x2::transfer;    
    use 0x2::tx_context::TxContext;    
    use 0x2::vector;    
    
    /// Minimal parameter set for Phase-1 (AIOc uses 18dp off-chain convention)    
    struct Params has store {    
        per_capita_min_aioc: u64,    
        bond_floor_aioc: u64,    
        challenge_bond_bps_floor: u64,  // e.g. 100 = 1%    
        degraded_large_move_bps: u64,   // e.g. 500 = 5%    
        max_stale_epochs: u64    
    }    
    
    struct Elders has store { addrs: vector<address> } // 3 addresses in Phase-1    
    
    struct Config has key, store {    
        id: object::UID,    
        params: Params,    
        elders: Elders,    
        mode_id: address,          // address of Mode object    
        governance_addr: address   // governance object addr (for auth)    
    }    
    
    public entry fun init(    
        e1: address, e2: address, e3: address,    
        per_capita_min_aioc: u64,    
        bond_floor_aioc: u64,    
        challenge_bps_floor: u64,    
        degraded_large_move_bps: u64,    
        max_stale_epochs: u64,    
        ctx: &mut TxContext    
    ) {    
        let params = Params {    
            per_capita_min_aioc,    
            bond_floor_aioc,    
            challenge_bond_bps_floor: challenge_bps_floor,    
            degraded_large_move_bps,    
            max_stale_epochs    
        };    
        let mut elders = Elders { addrs: vector::empty<address>() };    
        vector::push_back(&mut elders.addrs, e1);    
        vector::push_back(&mut elders.addrs, e2);    
        vector::push_back(&mut elders.addrs, e3);    
    
        let m = aio::mode::new(ctx);    
        let mode_id = object::id_address(aio::mode::id(&m));    
        aio::mode::share(m);    
    
        let g = aio::governance::new(ctx);    
        let governance_addr = object::id_address(aio::governance::id(&g));    
        aio::governance::share(g);    
    
        let cfg = Config {    
            id: object::new(ctx),    
            params,    
            elders,    
            mode_id,    
            governance_addr    
        };    
        transfer::share_object(cfg);    
    }    
    
    public fun elders(c: &Config): &vector<address> { &c.elders.addrs }    
    public fun params(c: &Config): &Params { &c.params }    
    public fun mode_addr(c: &Config): address { c.mode_id }    
    public fun governance_addr(c: &Config): address { c.governance_addr }    
}    
    
