module aio::mode {
    use 0x2::tx_context::{TxContext};
    use 0x2::object;
    use 0x2::transfer;
    use 0x2::clock::{Clock, timestamp_ms};

    const E_SABBATH: u64 = 2401;

    struct Mode has key, store { id: object::UID, v: u8 }

    public fun new(ctx: &mut TxContext): Mode { Mode { id: object::new(ctx), v: 0 } }
    public fun id(m: &Mode): &object::UID { &m.id }
    public fun get(m: &Mode): u8 { m.v }

    public entry fun set_degraded(cfg: &aio::config::Config, m: &mut Mode, ctx: &mut TxContext) {
        aio::governance::require_elder_sender(cfg, ctx);
        m.v = 1;
    }
    public entry fun set_halted(cfg: &aio::config::Config, m: &mut Mode, ctx: &mut TxContext) {
        aio::governance::require_elder_sender(cfg, ctx);
        m.v = 2;
    }
    public entry fun set_normal(cfg: &aio::config::Config, m: &mut Mode, ctx: &mut TxContext) {
        aio::governance::require_elder_sender(cfg, ctx);
        m.v = 0;
    }

    public fun guard_allow_reseal(_m: &Mode) { }
    public fun guard_large_treasury_move(_m: &Mode, _bps_threshold: u64) { }

    public fun share(m: Mode) { transfer::share_object(m) }

    /// Sabbath: true if within configured weekly window (UTC)
    public fun is_sabbath(now_ms: u64, p: &aio::config::Params): bool {
        let start_wd = aio::config::sabbath_start_weekday(p);
        let start_hr = aio::config::sabbath_start_hour_utc(p) as u64;
        let dur_hrs  = aio::config::sabbath_duration_hours(p) as u64;

        // Convert ms->seconds, compute weekday/hour in UTC from origin
        // We assume period_origin_ms is a stable epoch anchor (UTC midnight) to derive weekdays.
        let origin_ms = p.period_origin_ms;
        let total_sec = (now_ms / 1000) - (origin_ms / 1000);
        let hours     = total_sec / 3600;
        let weeks     = hours / (24 * 7);
        let hours_in_week = hours - (weeks * 24 * 7);
        let weekday = (hours_in_week / 24) as u8;   // 0..6
        let hour    = hours_in_week % 24;

        if (weekday != start_wd) return false;
        let within = hour >= start_hr && hour < (start_hr + dur_hrs);
        within
    }

    /// Abort if we are in Sabbath
    public fun require_not_sabbath(cfg: &aio::config::Config, clock: &Clock) {
        let p = aio::config::params(cfg);
        let now_ms = timestamp_ms(clock);
        assert!(!is_sabbath(now_ms, p), E_SABBATH);
    }
}


