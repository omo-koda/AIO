2) Escrow state machine tighten (no observable gap)

We already lock immediately after the state == 0 assert. To make intent explicit and keep analyzers happy, I removed the conditional message branch and kept a single code path.

escrow.move

module aio::escrow {
    // Error range 2100–2199
    const E_SELF: u64 = 2101;
    const E_ALREADY_FINAL: u64 = 2102;
    const E_ONLY_CLIENT: u64 = 2103;
    const E_IN_PROGRESS: u64 = 2104;

    public entry fun release<T>(
        cfg: &aio::config::Config,
        guard: &mut aio::receipts::ReceiptGuard,
        e: &mut Escrow<T>,
        clock: &Clock,
        ctx: &mut TxContext
    ) {
        // gates that must not mutate escrow state
        aio::mode::require_not_sabbath(cfg, clock);
        assert!(tx_context::sender(ctx) == e.client, E_ONLY_CLIENT);

        // single-shot + atomic lock
        assert!(e.state == 0, E_ALREADY_FINAL);
        e.state = 3; // lock immediately

        let p = aio::config::params(cfg);
        let now_ms = 0x2::clock::timestamp_ms(clock);
        let period = aio::config::compute_period(now_ms, p);

        aio::receipts::check_and_mark_used(cfg, guard, e.rid, period);

        let amt = balance::value(&e.amount);
        let tithe_bps = aio::config::tithe_bps(p);
        let tithe = aio::finance::tithe_amount(amt, tithe_bps);
        let net = amt - tithe;

        let c_net = coin::from_balance(balance::withdraw(&mut e.amount, net), ctx);
        let c_tithe = coin::from_balance(balance::withdraw(&mut e.amount, tithe), ctx);

        transfer::public_transfer(c_net, e.worker);
        transfer::public_transfer(c_tithe, aio::config::tithe_wallet(p));

        e.state = 1;
        aio::events::emit_work_receipt(e.rid, e.worker, period as u32, amt);
    }

    public entry fun refund<T>(
        cfg: &aio::config::Config,
        e: &mut Escrow<T>,
        clock: &Clock,
        ctx: &mut TxContext
    ) {
        aio::mode::require_not_sabbath(cfg, clock);
        assert!(tx_context::sender(ctx) == e.client, E_ONLY_CLIENT);

        assert!(e.state == 0, E_ALREADY_FINAL);
        e.state = 3; // lock
        let back = coin::from_balance(balance::withdraw(&mut e.amount, balance::value(&e.amount)), ctx);
        transfer::public_transfer(back, e.client);
        e.state = 2;
    }

    /// Move Prover: no escrow persists with state == 3
    spec module {
        invariant update forall e: Escrow: e.state != 3;
    }
}


