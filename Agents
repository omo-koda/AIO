#!/usr/bin/env python3
import sys, json, base64, hashlib
from hashlib import blake2b
from nacl.signing import VerifyKey
from nacl.exceptions import BadSignatureError

def sui_address_from_ed25519_pub(pubkey_bytes: bytes) -> str:
    # Sui address = BLAKE2b-256( scheme_flag(0x00) || pubkey ) as 32-byte hex with 0x prefix
    h = blake2b(digest_size=32)
    h.update(b"\x00" + pubkey_bytes)
    return "0x" + h.hexdigest()

def norm_addr(x: str) -> str:
    x = x.lower()
    if not x.startswith("0x"): x = "0x" + x
    # left-pad to 64 hex chars after 0x for a canonical compare
    n = x[2:]
    n = n.rjust(64, "0")
    return "0x" + n

def main(challenge_path, attestations_path):
    challenge = json.load(open(challenge_path, "rb"))
    atts = json.load(open(attestations_path, "rb"))

    payload = json.dumps(challenge, separators=(",", ":"), sort_keys=True).encode()

    elders = atts.get("elders", [])
    if len(elders) < 3:
        sys.exit("FAIL: expected >=3 elder attestations")

    for e in elders:
        addr = norm_addr(e["address"])
        pk_b64 = e["pubkey_b64"]
        sig_b64 = e["signature_b64"]

        pub = base64.b64decode(pk_b64)
        sig = base64.b64decode(sig_b64)

        # 1) Address binding
        derived = norm_addr(sui_address_from_ed25519_pub(pub))
        if derived != addr:
            sys.exit(f"FAIL: address/pubkey mismatch for {addr}")

        # 2) Signature validity on the canonical challenge payload
        try:
            VerifyKey(pub).verify(payload, sig)
        except BadSignatureError:
            sys.exit(f"FAIL: invalid signature for {addr}")

    print("OK")

if __name__ == "__main__":
    if len(sys.argv) != 3:
        print("Usage: verify_ed25519_and_addr.py elder_challenge.json elder_attestations.json")
        sys.exit(1)
    main(sys.argv[1], sys.argv[2])

Why this is correct: Sui derives addresses by hashing the signature-scheme flag (Ed25519 = 0x00) concatenated with the raw public key using BLAKE2b-256, producing a 32-byte address. We perform that derivation and compare to the submitted address, then verify the ed25519 signature over the canonical challenge JSON. 


