# --- add near the other Ed25519 constants ---
L = 2**252 + 27742317777372353535851937790883648493  # ed25519 group order

def is_on_curve(x: int, y: int) -> bool:
    # Edwards25519 curve: -x^2 + y^2 = 1 + d x^2 y^2  (mod p)
    return ((-x*x + y*y) - (1 + D*x*x*y*y)) % P == 0

def is_identity(Pt: tuple[int,int]) -> bool:
    # Identity in Edwards coords is (0,1)
    return Pt == (0, 1)

def decode_point(s: bytes) -> tuple[int,int]:
    if len(s) != 32:
        raise ValueError("point length")
    y = int.from_bytes(s, "little") & ((1 << 255) - 1)
    x_sign = (s[31] >> 7) & 1
    y2 = (y * y) % P
    u = (y2 - 1) % P
    v = (D * y2 + 1) % P
    x2 = (u * inv(v)) % P
    x = pow(x2, (P + 3) // 8, P)
    if (x * x - x2) % P != 0:
        x = (x * I) % P
    if (x & 1) != x_sign:
        x = (-x) % P
    # NEW: strict curve membership check
    if not is_on_curve(x, y):
        raise ValueError("point not on curve")
    return (x, y)

def ed25519_verify(message: bytes, sig: bytes, pubkey: bytes) -> bool:
    if len(pubkey) != 32 or len(sig) != 64:
        return False
    R_enc = sig[:32]
    S = int.from_bytes(sig[32:], "little")
    # Basic scalar bounds; RFC8032 allows S < L, but this tighter bound is fine
    if S >= L:
        return False
    try:
        A = decode_point(pubkey)
        R = decode_point(R_enc)
    except Exception:
        return False
    # NEW: prime-order subgroup check (defense in depth)
    # Reject low-order / torsion points: verify [L]A == identity
    if not is_identity(scalarmult(A, L)):
        return False
    h = hashlib.sha512(R_enc + pubkey + message).digest()
    h_int = int.from_bytes(h, "little") % L
    SB = scalarmult(BASE, S)
    hA = scalarmult(A, h_int)
    Rp = edwards_add(R, hA)
    return point_encode(SB) == point_encode(Rp)


