    /// floor(amount * bps / 10000) using 128-bit intermediate
    public fun amount_from_bps(amount: u64, bps: u64): u64 {
        let prod: u128 = (amount as u128) * (bps as u128);
        (prod / 10000) as u64
    }

    public fun tithe_amount(amount: u64, bps: u64): u64 {
        let t = amount_from_bps(amount, bps);
        assert!(t < (amount / 2), E_TITHE_TOO_HIGH);
        t
    }
