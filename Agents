def verify_sui_binary(expected_sha256: str):
    path = shutil.which("sui")
    if not path or not os.path.exists(path):
        raise SystemExit("FAIL: 'sui' binary not found on PATH")
    h = hashlib.sha256()
    with open(path, "rb") as f:
