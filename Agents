#!/usr/bin/env python3
# Requires: python3 -m pip install pynacl
import sys, json, base64
from nacl.signing import VerifyKey
from nacl.exceptions import BadSignatureError

def hex_to_bytes(h):
    h = h.lower()
    assert h.startswith("0x"), "pubkey must start with 0x"
    b = bytes.fromhex(h[2:])
    if len(b) != 32: raise ValueError("pubkey must be 32 bytes")
    return b

def main(challenge_path, attestations_path):
    with open(challenge_path, "rb") as f:
        msg = f.read()  # exact bytes of elder_challenge.json
    atts = json.load(open(attestations_path, "r"))

    # Basic structure
    assert isinstance(atts, list) and len(atts) == 3
    addrs = set()
    for a in atts:
        for k in ("address","pubkey_hex","sig_b64","timestamp"):
            assert k in a
        addrs.add(a["address"])

    # Cross-check addresses cover challenge elders
    ch = json.loads(open(challenge_path, "r", encoding="utf-8").read())
    ch_addrs = set(ch["elders"])
    if addrs != set(ch_addrs):
        raise SystemExit("Attestation addresses != challenge elders")

    # Verify each sig
    for a in atts:
        pk = VerifyKey(hex_to_bytes(a["pubkey_hex"]))
        sig = base64.b64decode(a["sig_b64"])
        if len(sig) != 64:
            raise SystemExit("signature must be raw 64 bytes (base64 encoded)")
        try:
            pk.verify(msg, sig)
        except BadSignatureError:
            raise SystemExit(f"Bad signature for {a['address']}")

    print("OK: all elder signatures valid over canonical challenge bytes")

if __name__ == "__main__":
    if len(sys.argv) != 3:
        print("Usage: verify_ed25519.py elder_challenge.json elder_attestations.json", file=sys.stderr)
        sys.exit(2)
    main(sys.argv[1], sys.argv[2])

