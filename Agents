module aio::merkle_sum {    
    use 0x2::hash;    
    use 0x2::vector;    
    
    /// Node hash: H(left || right || count64_le)    
    public fun inner_hash(l: vector<u8>, r: vector<u8>, cnt: u64): vector<u8> {    
        let mut data = l;    
        vector::append(&mut data, r);    
        // append cnt as little-endian 8 bytes    
        let b0 = (cnt & 0xFF) as u8;    
        let b1 = ((cnt >> 8) & 0xFF) as u8;    
        let b2 = ((cnt >> 16) & 0xFF) as u8;    
        let b3 = ((cnt >> 24) & 0xFF) as u8;    
        let b4 = ((cnt >> 32) & 0xFF) as u8;    
        let b5 = ((cnt >> 40) & 0xFF) as u8;    
        let b6 = ((cnt >> 48) & 0xFF) as u8;    
        let b7 = ((cnt >> 56) & 0xFF) as u8;    
        vector::push_back(&mut data, b0);    
        vector::push_back(&mut data, b1);    
        vector::push_back(&mut data, b2);    
        vector::push_back(&mut data, b3);    
        vector::push_back(&mut data, b4);    
        vector::push_back(&mut data, b5);    
        vector::push_back(&mut data, b6);    
        vector::push_back(&mut data, b7);    
        hash::sha3_256(data)    
    }    
    
    /// Byte-wise big-endian compare for 32B keys    
    public fun cmp32(a: &vector<u8>, b: &vector<u8>): i8 {    
        let n = 32;    
        let mut i = 0;    
        while (i < n) {    
            let ai = *vector::borrow(a, i);    
            let bi = *vector::borrow(b, i);    
            if (ai < bi) return -1;    
