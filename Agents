def validate_order_and_lineage(m, pkg_hex):
    digs = m["transaction_evidence"]
    txs = {k: safe_fetch_tx(v) for k,v in digs.items()}

    # Time order (strictly increasing)
    seq = ["config_init","oracle_issue_nonce","oracle_register","escrow_test","root_seal","prune_pre","prune_post"]
