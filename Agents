def point_double(Pt: tuple[int,int]) -> tuple[int,int]:
    (x, y) = Pt
    x2, y2 = (x * x) % P, (y * y) % P
    xy2 = (2 * x * y) % P
    denom1 = inv((2 - x2 - y2) % P)
    denom2 = inv((x2 + y2) % P)
    x3 = (xy2 * denom1) % P
    y3 = ((y2 - x2) * denom2) % P
    return (x3, y3)

def mul8(Pt: tuple[int,int]) -> tuple[int,int]:
