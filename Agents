# NOTE: Pure-stdlib Ed25519 verification (RFC 8032) — concise reference impl.
#       This is sufficient for verifying elder attestations. For performance,
#       we keep it minimal and readable; not constant-time.

# Field operations for Ed25519
P = 2**255 - 19
D = -121665 * pow(121666, -1, P) % P
I = pow(2, (P-1)//4, P)  # sqrt(-1) mod p

def inv(z: int) -> int: return pow(z, P-2, P)

def edwards_add(P1, P2):
    (x1,y1) = P1; (x2,y2) = P2
    x3 = ((x1*y2 + x2*y1) * inv(1 + D*x1*x2*y1*y2 % P)) % P
    y3 = ((y1*y2 + x1*x2) * inv(1 - D*x1*x2*y1*y2 % P)) % P
    return (x3, y3)

def edwards_double(Pt):
    return edwards_add(Pt, Pt)

def decode_point(s: bytes) -> Tuple[int,int]:
    if len(s) != 32: raise ValueError("point length")
    y = int.from_bytes(s, "little") & ((1<<255)-1)
    x_sign = (s[31] >> 7) & 1
    # x recover: x^2 = (y^2 - 1)/(d y^2 + 1)
    y2 = (y*y) % P
    u = (y2 - 1) % P
    v = (D*y2 + 1) % P
    x2 = (u * inv(v)) % P
    x = pow(x2, (P+3)//8, P)
    if (x*x - x2) % P != 0:
        x = (x * I) % P
    if x % 2 != x_sign:
        x = (-x) % P
    return (x, y)

# Base point
Bx = 15112221349535400772501151409588531511454012693041857206046113283949847762202
By = 46316835694926478169428394003475163141307993866256225615783033603165251855960
BASE = (Bx, By)

def scalarmult(Pt, e: int):
    Q = (0,1)
    for i in range(256):
        if (e >> i) & 1:
            Q = edwards_add(Q, Pt)
        Pt = edwards_double(Pt)
    return Q

def point_encode(Pt) -> bytes:
    (x,y) = Pt
    s = (y | ((x & 1) << 255)).to_bytes(32, "little")
    return s

def ed25519_verify(message: bytes, sig: bytes, pubkey: bytes) -> bool:
    if len(pubkey) != 32 or len(sig) != 64:
        return False
    R_enc = sig[:32]
    S = int.from_bytes(sig[32:], "little")
    if S >= 2**252:  # basic bound check
        return False
    try:
        A = decode_point(pubkey)
        R = decode_point(R_enc)
    except Exception:
        return False
    h = hashlib.sha512(R_enc + pubkey + message).digest()
    h_int = int.from_bytes(h, "little")
    # Check: [S]B = R + [h]A
    SB = scalarmult(BASE, S)
    hA = scalarmult(A, h_int)
    Rp = edwards_add(R, hA)
    return point_encode(SB) == point_encode(Rp)

def sui_address_from_ed25519_pubkey(pubkey: bytes) -> str:
    if len(pubkey) != 32:
        raise ValueError(f"Ed25519 pubkey must be 32 bytes, got {len(pubkey)}")
    # Sui address derivation: blake2b-256(flag||pubkey), flag=0x00 for ed25519
    h = hashlib.blake2b(digest_size=32)
    h.update(b"\x00" + pubkey)
    return "0x" + h.hexdigest()

