module aio::receipts {
    use 0x2::object;
    use 0x2::transfer;
    use 0x2::tx_context::TxContext;
    use 0x2::vector;
    use 0x2::table::{Self, Table};
    use 0x2::clock::{Clock, timestamp_ms};

    const E_DUPLICATE: u64 = 2201;
    const E_PERIOD_MISMATCH: u64 = 2202;
    const E_TOO_SOON: u64 = 2203;
    const E_NOT_ELDER: u64 = 2204;

    /// Sealed monthly root (kept from Phase-1)
    struct ActiveRoot has key, store {
        id: object::UID,
        month: u32,
        root: vector<u8>,
        count: u64,
        epoch: u64
    }

    /// NEW: per-period guard for (rid,period) dedupe
    struct ReceiptGuard has key, store {
        id: object::UID,
        period: u32,
        used: Table<vector<u8>, bool>,
        created_at_ms: u64
    }

    public entry fun create_guard(
        cfg: &aio::config::Config,
        period: u32,
        clock: &Clock,
        ctx: &mut TxContext
    ): ReceiptGuard {
        // Elder-gated creation for a period (create at or near start of period)
        aio::governance::require_elder_sender(cfg, ctx);
        let g = ReceiptGuard {
            id: object::new(ctx),
            period,
            used: Table::new<vector<u8>, bool>(ctx),
            created_at_ms: timestamp_ms(clock)
        };
        transfer::share_object(g);
        g
    }

    /// Mark (rid,period) as used — the caller must pass the correct guard for that period.
    public fun check_and_mark_used(
        cfg: &aio::config::Config,
        guard: &mut ReceiptGuard,
        rid: vector<u8>,
        period: u32
    ) {
        let p = aio::config::params(cfg);
        assert!(guard.period == period, E_PERIOD_MISMATCH);
        if (Table::contains(&guard.used, &rid)) { abort E_DUPLICATE }
        Table::add(&mut guard.used, rid, true);
        let _ = p;
    }

    /// Elder-gated prune after seal + challenge window elapsed
    public entry fun prune_period_guard(
        cfg: &aio::config::Config,
        guard: &mut ReceiptGuard,
        clock: &Clock,
        _sealed_root: &ActiveRoot, // proof of sealing for this period (light-weight)
        ctx: &mut TxContext
    ) {
        // require elder
        aio::governance::require_elder_sender(cfg, ctx);

        let p = aio::config::params(cfg);
        let now_ms = timestamp_ms(clock);
        let age = now_ms - guard.created_at_ms;
        assert!(age >= aio::config::challenge_window_ms(p), E_TOO_SOON);

        // drop the table by reinitializing to an empty one
        guard.used = Table::new<vector<u8>, bool>(ctx);
    }

    public entry fun submit_root(
        cfg: &aio::config::Config,
        root: vector<u8>,
        count: u64,
        epoch: u64,
        ctx: &mut TxContext
    ) {
        aio::governance::require_elder_sender(cfg, ctx);
        let ar = ActiveRoot { id: object::new(ctx), month: 0, root, count, epoch };
        transfer::share_object(ar);
    }
}

> Usage pattern (Phase-1): Hold a single shared ReceiptGuard per period. escrow.release receives &mut ReceiptGuard for the current computed period and calls check_and_mark_used before emitting receipt. Ops prunes the guard after sealing + challenge window.




