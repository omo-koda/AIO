        let len_ms = p.period_length_sec * 1000;
        if (now_ms <= origin) return 0;
        ((now_ms - origin) / len_ms) as u32
    }

    /// Compute weekday (0..6) and hour-of-day from origin + provided origin weekday.
    public fun compute_weekday_hour(now_ms: u64, p: &Params): (u8, u64) {
        let delta_sec = (now_ms - p.period_origin_ms) / 1000;
        let days = delta_sec / 86400;
        let weekday = ((p.origin_weekday_utc as u64 + days) % 7) as u8;
        let hour = (delta_sec % 86400) / 3600;
        (weekday, hour)
    }

    // getters (add):
    public fun origin_weekday(p: &Params): u8 { p.origin_weekday_utc }
