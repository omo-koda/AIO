#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")"
source ./ceremony.env

python3 - <<PY
import math

origin = int("$PERIOD_ORIGIN_MS")
plen_ms = int("$PERIOD_LENGTH_SEC") * 1000

def period(ts):
    if ts < origin: raise SystemExit("ERROR: timestamp < origin")
    return (ts - origin) // plen_ms

# Test set: exact origin, boundary-1, boundary, several months span,
# leap-year dates (UTC), large ts guard (but stay within u64).
tests = [
    ("origin", origin, 0),
    ("boundary_minus_1", origin + plen_ms - 1, 0),
    ("boundary_exact", origin + plen_ms, 1),
    ("+2_periods", origin + 2*plen_ms + 12345, 2),
    ("leap_year_utc_check", 1767225600000, None),  # 2026-01-01 00:00:00 UTC (period computed, no DST ever)
    ("far_future_guard", origin + 36*plen_ms, 36)
]

ok = True
for name, ts, expected in tests:
    p = period(ts)
    if expected is not None and p != expected:
        print(f"[FAIL] {name}: expected {expected}, got {p}")
        ok = False
    else:
        print(f"[OK]   {name}: period={p}")

# Monotonicity over multi-year sweep
prev = period(origin)
for i in range(1, 36*30):  # ~90 months samples
    ts = origin + i * (plen_ms//30)
    pi = period(ts)
    if pi < prev:
        print("[FAIL] non-monotonic period at ts", ts)
        ok = False; break
    prev = pi

if not ok: raise SystemExit(1)
print("==> Period validation PASS")
PY

Expected: all [OK], then PASS.
Abort: any [FAIL] → fix params before init.

