def sha256_file(path: str) -> str:
    h = hashlib.sha256()
    try:
        with open(path, "rb") as f:
            for chunk in iter(lambda: f.read(65536), b""):
                h.update(chunk)
    except Exception as e:
        fatal(f"checksum read failed for {path}: {e}", E_CHECKSUMS)
    return h.hexdigest()

