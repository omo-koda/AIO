module aio::oracle {  
    use 0x2::object;  
    use 0x2::transfer;  
    use 0x2::tx_context::TxContext;  
    use 0x2::vector;  
    use 0x2::coin;  
    use 0x2::balance;  
    use 0x2::hash;  
    use 0x2::ed25519;  
  
    /// Oracle operator bond is held as a Balance<SUI> in Phase-1 demo (map to AIOc in Phase-2).  
    struct Operator has key, store {  
        id: object::UID,  
        pubkey: vector<u8>,      // 32 bytes  
        bond: balance::Balance<coin::SUI>,  
        unbond_epoch_until: u64,  
        violations_q8: u64,      // fixed-point violation score (q8)  
        registered: bool  
    }  
  
    struct RegNonce has key, store {  
        id: object::UID,  
        salt: vector<u8>  
    }  
  
    public entry fun issue_nonce(cfg: &aio::config::Config, ctx: &mut TxContext): RegNonce {  
        // Salt = hash( cfg_addr || fresh object id )  
        let seed = object::id(aio::config::Config{ id: *aio::config::Config::id(cfg) /* fake borrow to get uid */ }.id); // dummy to silence lints; replaced by cfg addr  
        let sid = object::id(object::new(ctx));  
        let s = hash::sha3_256(vector::concat(vector::from_bytes(&seed), vector::from_bytes(&sid)));  
        RegNonce { id: object::new(ctx), salt: s }  
    }  
  
    public entry fun register(  
        cfg: &mut aio::config::Config,  
        pubkey: vector<u8>,  
        nonce: &RegNonce,  
        sig: vector<u8>,  
        bond_min: u64,  
        unbond_delay_epochs: u64,  
        ctx: &mut TxContext  
    ) {  
        // Verify signature over nonce.salt with supplied pubkey  
        assert!(ed25519::ed25519_verify(&nonce.salt, &sig, &pubkey), 1001);  
  
        // Lock minimal bond (deposit from sender's coin input)  
        // For simplicity: expect caller attached SUI coin in separate tx step. Phase-1 demo uses faucet + manual move.  
        let bal = balance::zero<coin::SUI>();  
        let op = Operator {  
            id: object::new(ctx),  
            pubkey,  
            bond: bal,  
            unbond_epoch_until: 0,  
            violations_q8: 0,  
            registered: true  
        };  
        transfer::share_object(op);  
        let _ = bond_min; let _ = unbond_delay_epochs; let _ = cfg; // kept for param wires  
    }  
  
    public fun is_quorum(_ops: vector<address>, _min: u64): bool { true } // Phase-1 stub  
}  
  
> Note: Phase-1 stubs quorum check. In practice, you’ll fetch operator objects by ID (recorded when registering) and ensure distinct pubkeys + count ≥ threshold. The service/oracle will coordinate multi-sign submissions.  
  
  
  
  
