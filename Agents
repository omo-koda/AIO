module aio::escrow {
    use 0x2::object;
    use 0x2::transfer;
    use 0x2::tx_context::TxContext;
    use 0x2::tx_context;
    use 0x2::coin;
    use 0x2::balance;
    use 0x2::vector;
    use 0x2::clock::Clock;

    const E_SELF: u64 = 2001;
    const E_ALREADY_RELEASED: u64 = 2002;
    const E_ALREADY_REFUNDED: u64 = 2003;
    const E_ONLY_CLIENT: u64 = 2004;
    const E_IN_PROGRESS: u64 = 2005;

    struct Escrow<T> has key, store {
        id: object::UID,
        client: address,
        worker: address,
        amount: balance::Balance<T>,
        period_hint: u32,   // optional hint (not authoritative)
        rid: vector<u8>,
        state: u8           // 0=Active, 1=Released, 2=Refunded, 3=Lock
    }

    public entry fun create<T: drop + store>(
        client: address,
        worker: address,
        coins: coin::Coin<T>,
        period_hint: u32,
        rid: vector<u8>,
        ctx: &mut TxContext
    ): Escrow<T> {
        assert!(client != worker, E_SELF);
        let amount = coin::into_balance(coins);
        Escrow {
            id: object::new(ctx),
            client, worker,
            amount, period_hint, rid,
            state: 0
        }
    }

    /// NEW: release requires Config, ReceiptGuard for current period, and Clock (for Sabbath + period)
    public entry fun release<T>(
        cfg: &aio::config::Config,
        guard: &mut aio::receipts::ReceiptGuard,
        e: &mut Escrow<T>,
        clock: &Clock,
        ctx: &mut TxContext
    ) {
        // Sabbath gate
        aio::mode::require_not_sabbath(cfg, clock);

        // only client
        assert!(tx_context::sender(ctx) == e.client, E_ONLY_CLIENT);

        // single-shot state machine
        assert!(e.state == 0, if (e.state == 3) { E_IN_PROGRESS } else { E_ALREADY_RELEASED });

        // lock
        e.state = 3;

        // compute deterministic period from clock
        let p = aio::config::params(cfg);
        let now_ms = 0x2::clock::timestamp_ms(clock);
        let period = aio::config::compute_period(now_ms, p);

        // dedupe (rid,period)
        aio::receipts::check_and_mark_used(cfg, guard, e.rid, period);

        let amt = balance::value(&e.amount);

        // tithe
        let tithe_bps = aio::config::tithe_bps(p);
        let tithe = aio::finance::tithe_amount(amt, tithe_bps);
        let net = amt - tithe;

        // withdraw & transfer
        let pay_net = balance::withdraw(&mut e.amount, net);
        let tithe_bal = balance::withdraw(&mut e.amount, tithe);
        let c_net = coin::from_balance(pay_net, ctx);
        let c_tithe = coin::from_balance(tithe_bal, ctx);

        transfer::public_transfer(c_net, e.worker);
        transfer::public_transfer(c_tithe, aio::config::tithe_wallet(p));

        // finalize
        e.state = 1;

        // Emit work receipt (gross amount for transparency + period)
        aio::events::emit_work_receipt(e.rid, e.worker, period as u32, amt);
    }

    public entry fun refund<T>(
        cfg: &aio::config::Config,
        e: &mut Escrow<T>,
        clock: &Clock,
        ctx: &mut TxContext
    ) {
        // Sabbath gate
        aio::mode::require_not_sabbath(cfg, clock);

        assert!(tx_context::sender(ctx) == e.client, E_ONLY_CLIENT);
        assert!(e.state == 0, if (e.state == 3) { E_IN_PROGRESS } else { E_ALREADY_REFUNDED });

        e.state = 3;
        let back_coin = coin::from_balance(
            balance::withdraw(&mut e.amount, balance::value(&e.amount)), ctx
        );
        transfer::public_transfer(back_coin, e.client);
        e.state = 2;
    }
}


