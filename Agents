    for i, line in enumerate(lines, 1):
        parts = line.strip().split()
        if len(parts) < 2:
            fatal(f"malformed checksums.sha256 at line {i}", E_CHECKSUMS)
        expected = parts[0]
        relpath = " ".join(parts[1:]).strip()
        # common formats: "<hash>  path" OR "<hash> path"
