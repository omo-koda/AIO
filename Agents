module aio::oracle {    
    use 0x2::object;    
    use 0x2::transfer;    
    use 0x2::tx_context::{TxContext};    
    use 0x2::vector;    
    use 0x2::coin;    
    use 0x2::balance;    
    use 0x2::hash;    
    use 0x2::ed25519;    
    use 0x2::bcs;    
    use 0x2::tx_context;    
    
    /// Oracle operator bond is held as a Balance<SUI> in Phase-1 demo    
    struct Operator has key, store {    
        id: object::UID,    
        pubkey: vector<u8>,      // 32 bytes    
        bond: balance::Balance<coin::SUI>,    
        unbond_epoch_until: u64,    
        violations_q8: u64,      // fixed-point violation score (q8)    
        registered: bool    
    }    
    
    struct RegNonce has key, store {    
        id: object::UID,    
        salt: vector<u8>    
    }    
    
    /// Deterministic salt from (sender || this nonce object's address)    
    public entry fun issue_nonce(_cfg: &aio::config::Config, ctx: &mut TxContext): RegNonce {    
        let sender = tx_context::sender(ctx);    
        let uid = object::new(ctx);    
        let addr = object::id_address(&uid);    
        let mut data = bcs::to_bytes(&sender);    
        let addr_bytes = bcs::to_bytes(&addr);    
        vector::append(&mut data, addr_bytes);    
        let s = hash::sha3_256(data);    
        RegNonce { id: uid, salt: s }    
    }    
    
    public entry fun register(    
        _cfg: &mut aio::config::Config,    
        pubkey: vector<u8>,    
        nonce: &RegNonce,    
        sig: vector<u8>,    
        bond_min: u64,    
        unbond_delay_epochs: u64,    
        deposit: coin::Coin<coin::SUI>,    
        ctx: &mut TxContext    
    ) {    
        // Verify signature over nonce.salt with supplied pubkey    
        assert!(ed25519::ed25519_verify(&nonce.salt, &sig, &pubkey), 1001);    
    
        // Convert deposit to balance and enforce minimum    
        let mut bal = coin::into_balance(deposit);    
        let v = balance::value(&bal);    
        assert!(v >= bond_min, 1002);    
    
        let op = Operator {    
            id: object::new(ctx),    
            pubkey,    
            bond: bal,    
            unbond_epoch_until: 0,  // TODO Phase-2: set epoch + delay    
            violations_q8: 0,    
            registered: true    
        };    
        transfer::share_object(op);    
        let _ = unbond_delay_epochs;    
    }    
    
    public fun is_quorum(_ops: vector<address>, _min: u64): bool { true } // Phase-1 stub    
}    
    
