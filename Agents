    use 0x2::tx_context::TxContext;
    use 0x2::coin;
    use 0x2::balance;
    use 0x2::vector;
    use 0x2::clock::Clock;

    const E_BAD_SPLIT: u64 = 3001;

    struct OfferConfig has key, store {
        id: object::UID,
        w1: address, w2: address, w3: address, w4: address,
        p1: u16, p2: u16, p3: u16, p4: u16 // basis points, must sum to 10000
    }

    public entry fun init_config(
        w1: address, w2: address, w3: address, w4: address,
        ctx: &mut TxContext
    ): OfferConfig {
        // fixed split 50/25/15/10 (5000/2500/1500/1000)
        let cfg = OfferConfig {
            id: object::new(ctx),
            w1, w2, w3, w4,
            p1: 5000, p2: 2500, p3: 1500, p4: 1000
        };
        transfer::share_object(cfg);
        cfg
    }

    public entry fun offer<T>(
        aio_cfg: &aio::config::Config,     // for period calc + sabbath gate
        cfg: &OfferConfig,
        coins: coin::Coin<T>,
        rid: vector<u8>,
        clock: &Clock,
        ctx: &mut TxContext
    ) {
        // Honor Sabbath globally (shared rhythm)
        aio::mode::require_not_sabbath(aio_cfg, clock);

        let total = coin::value(&coins);
        let p = aio::config::params(aio_cfg);
        let period = aio::config::compute_period(0x2::clock::timestamp_ms(clock), p);

        // Split with deterministic rounding: remainder to w1
        let mut bal = coin::into_balance(coins);
        let a1 = (total / 10000) * (cfg.p1 as u64);
        let a2 = (total / 10000) * (cfg.p2 as u64);
        let a3 = (total / 10000) * (cfg.p3 as u64);
        let base = a1 + a2 + a3;
        let a4 = if (total >= base) { total - base } else { 0 };

        assert!(a1 + a2 + a3 + a4 == total, E_BAD_SPLIT);

        let c1 = coin::from_balance(balance::withdraw(&mut bal, a1), ctx);
        let c2 = coin::from_balance(balance::withdraw(&mut bal, a2), ctx);
        let c3 = coin::from_balance(balance::withdraw(&mut bal, a3), ctx);
        let c4 = coin::from_balance(balance::withdraw(&mut bal, a4), ctx);

        transfer::public_transfer(c1, cfg.w1);
        transfer::public_transfer(c2, cfg.w2);
        transfer::public_transfer(c3, cfg.w3);
        transfer::public_transfer(c4, cfg.w4);

        // Emit ritual receipt
        techgnos::ritual_receipts::emit_ritual_receipt(rid, 1u8, 0x2::tx_context::sender(ctx), total, period);
    }
