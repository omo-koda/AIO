        if a in ts and b in ts and ts[a] >= ts[b]:
            raise SystemExit(f"FAIL: {a} must precede {b} (timestamps out of order)")

    # Lineage: the RegNonce deleted in register must equal the RegNonce created in issue_nonce
    def created_ids(tx, typ):
        return [c["objectId"] for c in tx.get("objectChanges", [])
                if c.get("type")=="created" and c.get("objectType")==typ]

    def deleted_ids(tx, typ):
        return [c["objectId"] for c in tx.get("objectChanges", [])
                if c.get("type")=="deleted" and c.get("objectType")==typ]

    regnonce_t = f"{pkg_hex}::oracle::RegNonce"
    nonce_created = created_ids(txs["oracle_issue_nonce"], regnonce_t)
    nonce_deleted = deleted_ids(txs["oracle_register"],   regnonce_t)

