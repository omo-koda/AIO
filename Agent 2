module aio::escrow {    
    use 0x2::object;    
    use 0x2::transfer;    
    use 0x2::tx_context::TxContext;    
    use 0x2::tx_context;    
    use 0x2::coin;    
    use 0x2::balance;    
    use 0x2::vector;    
    
    struct Escrow<T> has key, store {    
        id: object::UID,    
        client: address,    
        worker: address,    
        amount: balance::Balance<T>,    
        period: u32,    
        rid: vector<u8>,    
        released: bool,    
        refunded: bool    
    }    
    
    public entry fun create<T: drop + store>(    
        client: address,    
        worker: address,    
        coins: coin::Coin<T>,    
        period: u32,    
        rid: vector<u8>,    
        ctx: &mut TxContext    
    ): Escrow<T> {    
        assert!(client != worker, 2001);    
        let amount = coin::into_balance(coins);    
        Escrow {    
            id: object::new(ctx),    
            client, worker,    
            amount, period, rid,    
            released: false, refunded: false    
        }    
    }    
    
    public entry fun release<T>(    
        e: &mut Escrow<T>,    
        ctx: &mut TxContext    
    ) {    
        assert!(!e.released && !e.refunded, 2002);    
        // Only the client may release in Phase-1.    
        assert!(tx_context::sender(ctx) == e.client, 2004);    
        let amt = balance::value(&e.amount);    
        let pay = balance::withdraw(&mut e.amount, amt);    
        let coinp = coin::from_balance(pay, ctx);    
        transfer::public_transfer(coinp, e.worker);    
        e.released = true;    
        // Emit work receipt (event) with actual amount    
        aio::events::emit_work_receipt(e.rid, e.worker, e.period, amt);    
    }    
    
    public entry fun refund<T>(    
        e: &mut Escrow<T>,    
        ctx: &mut TxContext    
    ) {    
        assert!(!e.released && !e.refunded, 2003);    
        // Only the client may refund in Phase-1.    
        assert!(tx_context::sender(ctx) == e.client, 2005);    
        let back_coin = coin::from_balance(    
            balance::withdraw(&mut e.amount, balance::value(&e.amount)), ctx    
        );    
        transfer::public_transfer(back_coin, e.client);    
        e.refunded = true;    
    }    
}    
    
    
