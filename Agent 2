module aio::mode {  
    use 0x2::tx_context::{TxContext};  
    use 0x2::object;  
    use 0x2::transfer;  
  
    /// 0 = Normal, 1 = Degraded, 2 = Halted  
    struct Mode has key, store { id: object::UID, v: u8 }  
  
    public fun new(ctx: &mut TxContext): Mode { Mode { id: object::new(ctx), v: 0 } }  
    public fun id(m: &Mode): &object::UID { &m.id }  
    public fun get(m: &Mode): u8 { m.v }  
  
    public fun set_degraded(m: &mut Mode) { m.v = 1 }  
    public fun set_halted(m: &mut Mode) { m.v = 2 }  
    public fun set_normal(m: &mut Mode) { m.v = 0 }  
  
    public fun guard_allow_reseal(m: &Mode) { /* always allowed */ }  
    public fun guard_large_treasury_move(m: &Mode, bps_threshold: u64) {  
        // If degraded(1), large moves are blocked by higher layers (treasury).  
        // No-op guard here; treasury checks it using this flag.  
        let _ = bps_threshold;  
    }  
  
    public fun share(m: Mode) { transfer::share_object(m) }  
}  
  
  
