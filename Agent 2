#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."
source .env
source .package.env

PUBS=()
[ -n "${ORACLE_1_PUB:-}" ] && PUBS+=("$ORACLE_1_PUB")
[ -n "${ORACLE_2_PUB:-}" ] && PUBS+=("$ORACLE_2_PUB")
[ -n "${ORACLE_3_PUB:-}" ] && PUBS+=("$ORACLE_3_PUB")
[ -n "${ORACLE_4_PUB:-}" ] && PUBS+=("$ORACLE_4_PUB")

if [ ${#PUBS[@]} -eq 0 ]; then
  echo "No ORACLE_X_PUB provided in .env" >&2
  exit 1
fi

for PUB in "${PUBS[@]}"; do
  echo "[oracle] issuing nonce for pub=$PUB ..."
  NONCE_ID=$(sui client call \
    --package "$AIO_CORE_PACKAGE_ID" \
    --module oracle \
    --function issue_nonce \
    --args "$CFG_ID" \
    --gas-budget 5000000 --json \
    | jq -r '.effects.created[]?.reference.objectId' | head -1)

  if [ -z "$NONCE_ID" ] || [ "$NONCE_ID" = "null" ]; then
    echo "Failed to get RegNonce id" >&2
