  const [stepsPerEpisode, setStepsPerEpisode] = useState(500);
  const [running, setRunning] = useState(false);
  const [results, setResults] = useState([]);

  const runEpisodes = async () => {
    setRunning(true);
    setResults([]);
    try {
      const resp = await fetch('http://localhost:8000/run_episodes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ num_episodes: numEpisodes, steps_per_episode: stepsPerEpisode })
      });
      const data = await resp.json();
      setResults(data);
    } catch (err) {
      console.error(err);
    }
    setRunning(false);
  };

  const exportResults = () => {
    const blob = new Blob([JSON.stringify(results, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = 'episode_metrics.json';
    link.click();
  };

  return (
    <div>
      <h2>Episode Control Panel</h2>
      <label>
        Number of Episodes:
        <input type="number" value={numEpisodes} onChange={e => setNumEpisodes(Number(e.target.value))} />
      </label>
      <label>
        Steps per Episode:
        <input type="number" value={stepsPerEpisode} onChange={e => setStepsPerEpisode(Number(e.target.value))} />
      </label>
      <button onClick={runEpisodes} disabled={running}>{running ? 'Running...' : 'Run Episodes'}</button>
      <button onClick={exportResults} disabled={results.length === 0}>Export Results</button>
      {results.length > 0 && (
        <div>
          <h3>Episode Summary</h3>
          <pre>{JSON.stringify(results, null, 2)}</pre>
        </div>
      )}
    </div>
  );
}


