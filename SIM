        # )

        # Async loop for Gazebo -> Unitree synchronization
        self.loop = asyncio.get_event_loop()
        self.loop.create_task(self.sync_gazebo_to_unitree())

    async def sync_gazebo_to_unitree(self):
        while rclpy.ok():
            state = await self.gazebo.get_robot_state()
            self.apply_veil_adjustments(state)
            # TODO: convert state to LowCmd and publish to robot
            # self.pub.publish(low_cmd_msg)
            self.get_logger().info(f"Synced Veils Active: {sum(1 for v in state['veil_states'].values() if v)}")
            await asyncio.sleep(0.05)  # 20Hz

    def apply_veil_adjustments(self, state):
        """
        Apply the full 200 Veils adjustments to the current robot state.
        This is where your Veil logic transforms joint positions or other parameters.
        """
        for i, (veil_name, veil_cfg) in enumerate(VEILS.items()):
            if veil_cfg["active"]:
                # Example: simple gain scaling
                for j in range(len(state["joint_positions"])):
                    state["joint_positions"][j] *= veil_cfg["params"]["gain"]

    # Placeholder for receiving real robot state
    # def state_callback(self, msg):
    #     # Map Unitree HighState msg to internal state or Veil logic
    #     pass

def main(args=None):
    rclpy.init(args=args)
    bridge = UnitreeBridge()
    try:
        rclpy.spin(bridge)
    except KeyboardInterrupt:
        pass
    finally:
        bridge.destroy_node()
        rclpy.shutdown()

if __name__ == "__main__":
