import React, { useEffect, useState } from 'react';
import RobotVisualizer from './RobotVisualizer';

export default function Dashboard() {
  const [robotState, setRobotState] = useState(null);
  const [commandResp, setCommandResp] = useState(null);
  const [gait, setGait] = useState('walk');

  useEffect(() => {
    const ws = new WebSocket('ws://localhost:8000/ws/state');
    ws.onmessage = (event) => {
      const data = JSON.parse(event.data);
      setRobotState(data);
    };
    return () => ws.close();
  }, []);

  useEffect(() => {
    const wsCmd = new WebSocket('ws://localhost:8000/ws/command');
    wsCmd.onmessage = (event) => {
      const data = JSON.parse(event.data);
      setCommandResp(data);
    };
    window.sendUnitreeCommand = (cmd) => {
      wsCmd.send(JSON.stringify(cmd));
    };
  }, []);

  const handleGaitChange = (e) => {
    setGait(e.target.value);
    window.sendUnitreeCommand({ action: 'set_gait', gait: e.target.value });
  };

  const resetRobot = () => {
    window.sendUnitreeCommand({ action: 'reset' });
  };

  return (
    <div>
      <h1>Simulation-as-a-Service Dashboard</h1>
      <div>
        <button onClick={resetRobot}>Reset Robot</button>
        <label>
          Select Gait:
          <select value={gait} onChange={handleGaitChange}>
            <option value="walk">Walk</option>
            <option value="trot">Trot</option>
            <option value="run">Run</option>
          </select>
        </label>
      </div>
      <RobotVisualizer state={robotState} />
      <pre>{JSON.stringify(robotState, null, 2)}</pre>
      <pre>{commandResp && JSON.stringify(commandResp, null, 2)}</pre>
    </div>
  );
}


