module aio::treasury {
    use 0x2::math64;

    /// Challenge bond calculator (Phase-1): max( per_capita_min*active , floor, 0.1%*treasury )
    public fun calc_challenge_bond(
        per_capita_min_aioc: u64,
        active: u64,
        bond_floor_aioc: u64,
        treasury_liquid_aioc: u64,
        floor_bps: u64 // e.g. 100 = 1%
    ): u64 {
        let per_cap = per_capita_min_aioc * active;
        let pct = (treasury_liquid_aioc / 10000) * floor_bps;
        let a = if (per_cap > bond_floor_aioc) per_cap else bond_floor_aioc;
        if (a > pct) a else pct
    }
