module aio::mode {
    use 0x2::tx_context::{TxContext};
    use 0x2::object;
    use 0x2::transfer;

    /// 0 = Normal, 1 = Degraded, 2 = Halted
    struct Mode has key, store { id: object::UID, v: u8 }

    public fun new(ctx: &mut TxContext): Mode { Mode { id: object::new(ctx), v: 0 } }
    public fun id(m: &Mode): &object::UID { &m.id }
    public fun get(m: &Mode): u8 { m.v }

