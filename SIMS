# backend/app/metrics_collector.py
import time, statistics, json, os
from typing import Dict, List

class MetricsCollector:
    def __init__(self, name="collector"):
        self.name = name
        self._samples: List[Dict] = []

    def record(self, sample: Dict):
        s = {"ts": time.time(), **sample}
        self._samples.append(s)

    def clear(self):
        self._samples.clear()

    def aggregate(self):
        if not self._samples:
            return {}
        # use specific keys
        joint_vels = [abs(sum(sample.get("joint_positions",[]))) for sample in self._samples]
        var = statistics.pvariance(joint_vels) if len(joint_vels)>1 else 0.0
        stability = 1.0/(1.0+var)
        safety_flags = [1 if sample.get("limit_violation",False) else 0 for sample in self._samples]
        safety = max(0.0, 1.0 - (sum(safety_flags)/max(1,len(safety_flags))))
        errors = [sample.get("goal_error",0.0) for sample in self._samples]
        eff = 1.0/(1.0+abs(statistics.mean(errors)) if errors else 0.0)
        return {"stability":stability,"safety":safety,"efficiency":eff,"samples":len(self._samples)}

class BaselineBuilder:
    def __init__(self):
        self.episodes = []

    def add_episode(self, metrics: Dict):
        self.episodes.append(metrics)

    def baseline_summary(self):
        keys = set().union(*(m.keys() for m in self.episodes)) if self.episodes else set()
        summary = {}
        import statistics
        for k in keys:
            vals = [m[k] for m in self.episodes if k in m]
            if not vals:
                summary[k] = {"mean":0.0,"std":0.0,"count":0}
            else:
                summary[k] = {"mean": float(statistics.mean(vals)),"std": float(statistics.pstdev(vals)),"count":len(vals)}
        return summary

    def save(self, path):
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path,"w") as f:
            json.dump({"baseline":self.baseline_summary(),"episodes":self.episodes}, f, indent=2)


