import statistics

class MetricsCollector:
    def __init__(self):
        self.records = []

    def record(self, values):
        self.records.append(values)

    def stability_score(self):
        var = statistics.pvariance([v for rec in self.records for v in rec])
        return 1.0 / (1.0 + var)

    def safety_score(self):
        violations = sum(1 for rec in self.records for v in rec if v < -1 or v > 1)
        return 1.0 - violations / (len(self.records) * len(self.records[0]))

    def task_efficiency(self):
        return sum(sum(rec) for rec in self.records) / len(self.records)


