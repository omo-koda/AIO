#!/usr/bin/env python3
# enhanced_veil_loader.py
import json
import logging
from typing import List, Callable

logger = logging.getLogger("EnhancedVeilLoader")
if not logger.handlers:
    ch = logging.StreamHandler()
    ch.setFormatter(logging.Formatter('%(asctime)s - %(levelname)s - %(message)s'))
    logger.addHandler(ch)
logger.setLevel(logging.INFO)

class EnhancedVeilLoader:
    def __init__(self, model, device='cpu', batch_size=50,
                 metrics_fn:Callable=None, anomaly_fn:Callable=None):
        self.model = model
        self.device = device
        self.batch_size = batch_size
        self.veils: List[float] = []
        self.index = 0
        self.metrics_fn = metrics_fn or (lambda m: {})
        self.anomaly_fn = anomaly_fn or (lambda pre, post: False)

    def load_from_json(self, path:str) -> bool:
        try:
            with open(path,'r') as f:
                data = json.load(f)
            self.veils = data.get("veils", [])
            self.index = 0
            logger.info(f"Loaded {len(self.veils)} veils from {path}")
            return True
        except Exception as e:
            logger.exception(f"Failed to load veil JSON {path}: {e}")
            return False

    def apply_next(self) -> bool:
        if self.index >= len(self.veils):
            logger.info("No more veils to apply")
            return False
        end_idx = min(self.index + self.batch_size, len(self.veils))
        batch = self.veils[self.index:end_idx]
        pre_metrics = self.metrics_fn(self.model)
        try:
            self.model.set_veil_weights(batch, start_index=0)
        except Exception:
            logger.exception("Failed to apply veil batch, rolling back")
            self.model.rollback_veil_weights()
            return False
        post_metrics = self.metrics_fn(self.model)
        if self.anomaly_fn(pre_metrics, post_metrics):
            logger.warn("Anomaly detected after veil application, rolling back")
            self.model.rollback_veil_weights()
            return False
        self.index = end_idx
        return True


