import React, { useEffect, useState } from 'react';
import RobotVisualizer from './RobotVisualizer';

export default function Dashboard() {
    const [simState, setSimState] = useState(null);
    const [unitreeState, setUnitreeState] = useState(null);

    useEffect(() => {
        const wsSim = new WebSocket('ws://localhost:8000/ws/state');
        wsSim.onmessage = (event) => setSimState(JSON.parse(event.data));

        const wsUnitree = new WebSocket('ws://localhost:8000/ws/unitree');
        wsUnitree.onmessage = (event) => setUnitreeState(JSON.parse(event.data));

        return () => {
            wsSim.close();
            wsUnitree.close();
        };
    }, []);

    return (
        <div>
            <h1>Simulation Dashboard</h1>
            <h2>Simulated Robot</h2>
            <RobotVisualizer state={simState} />
            <h2>Unitree Robot</h2>
            <RobotVisualizer state={unitreeState} />
        </div>
    );
}


