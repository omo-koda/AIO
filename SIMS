                }
                self.model._metrics.record(state)
        except Exception:
            self.get_logger().exception("control loop error - stopping")
            self.publish_stop()

    def publish_stop(self):
        stop_msg = Float64MultiArray()
        stop_msg.data = [0.0 for _ in JOINT_LIMITS]
        self.joint_pub.publish(stop_msg)

