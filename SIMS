# backend/app/veil_net.py
import torch
import torch.nn as nn
from typing import List

class VeilNet(nn.Module):
    def __init__(self, input_size:int=12, hidden_size:int=128, output_size:int=12):
        super().__init__()
        self.fc1 = nn.Linear(input_size, hidden_size)
        self.ln1 = nn.LayerNorm(hidden_size)
        self.fc2 = nn.Linear(hidden_size, hidden_size)
        self.ln2 = nn.LayerNorm(hidden_size)
        self.fc3 = nn.Linear(hidden_size, output_size)
        self._veil_state_snap = None
        self._metrics = None
        self.device = torch.device("cpu")

    def forward(self, x):
        x = torch.relu(self.ln1(self.fc1(x)))
        x = torch.relu(self.ln2(self.fc2(x)))
        return self.fc3(x)

    def set_veil_weights(self, batch: List[float], start_index: int = 0):
        flat_params = []
        for p in self.parameters():
            flat_params.extend(p.data.detach().cpu().flatten().tolist())
        if start_index + len(batch) > len(flat_params):
            raise ValueError("Batch too large for model parameters")
        self._veil_state_snap = [p.detach().cpu().clone() for p in self.parameters()]
        idx = start_index
        for p in self.parameters():
            numel = p.data.numel()
            chunk = batch[idx:idx+numel]
            if len(chunk) != numel:
                padded = chunk + p.data.detach().cpu().flatten().tolist()[len(chunk):]
                p.data.copy_(torch.tensor(padded, dtype=p.data.dtype).view(p.data.shape))
                idx += len(chunk)
            else:
                p.data.copy_(torch.tensor(chunk, dtype=p.data.dtype).view(p.data.shape))
                idx += numel

    def rollback_veil_weights(self):
        if self._veil_state_snap is None:
            raise RuntimeError("No snapshot to rollback to")
        for p, snap in zip(self.parameters(), self._veil_state_snap):
            p.data.copy_(snap.to(p.device))
        self._veil_state_snap = None

    def snapshot_state(self):
        self._veil_state_snap = [p.detach().cpu().clone() for p in self.parameters()]

    def restore_snapshot(self):
        return self.rollback_veil_weights()

    def get_current_veil_state(self):
        return {f"layer_{i}": p.detach().cpu().flatten().tolist()[:16] for i,p in enumerate(self.parameters())}


