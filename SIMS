import time
from collections import deque

class MetricsCollector:
    def __init__(self, name:str, maxlen:int=100):
        self.name = name
        self.data = deque(maxlen=maxlen)

    def record(self, metrics:dict):
        """Attach timestamp and store metrics"""
        entry = {"ts": time.time(), **metrics}
        self.data.append(entry)

    def aggregate(self):
        if not self.data:
            return {}
        agg = {}
        keys = self.data[0].keys() - {"ts"}
        for k in keys:
            agg[k] = sum(d[k] for d in self.data)/len(self.data)
        return agg

    def reset(self):
        self.data.clear()


