class VeilLoaderNode(Node):
    def __init__(self):
        super().__init__('veil_loader_node')
        self.get_logger().info("Starting VeilLoaderNode")
        self.model = VeilNet(input_size=12, hidden_size=128, output_size=12)
        self.model._metrics = MetricsCollector("robot_1")
        self.loader = EnhancedVeilLoader(self.model, device='cpu', batch_size=50,
                                         metrics_fn=lambda m: m._metrics.aggregate(),
                                         anomaly_fn=lambda pre, post: False)
        self.create_subscription(Float32MultiArray, 'veil_batch_input', self.batch_cb, 10)
        self.create_subscription(String, 'veil_cmd', self.cmd_cb, 10)

    def batch_cb(self, msg):
        try:
            floats = list(msg.data)
            self.loader.veils = floats
            self.loader.index = 0
            ok = self.loader.apply_next()
            self.get_logger().info(f"apply_next returned {ok}")
        except Exception as e:
            self.get_logger().error(f"batch_cb error: {e}")

    def cmd_cb(self, msg):
        try:
            payload = json.loads(msg.data)
            cmd = payload.get("cmd")
            if cmd == "load_file":
                ok = self.loader.load_from_json(payload.get("path"))
                self.get_logger().info(f"loaded file: {ok}")
            elif cmd == "apply_next":
                ok = self.loader.apply_next()
                self.get_logger().info(f"apply_next: {ok}")
            elif cmd == "rollback":
                ok = self.loader.model.rollback_veil_weights()
                self.get_logger().info(f"rollback: {ok}")
        except Exception:
            self.get_logger().exception("cmd_cb error")

