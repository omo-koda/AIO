import React from 'react';

export default function RobotVisualizer({ state }) {
    if (!state) return <div>Loading robot state...</div>;
    return (
        <div>
            <h2>Joint Positions:</h2>
            <ul>
                {state.joint_positions.map((pos, i) => (
                    <li key={i}>Joint {i}: {pos.toFixed(2)}</li>
                ))}
            </ul>
            <p>Safety State: {state.safety_state}</p>
            {state.battery && <p>Battery: {state.battery.toFixed(1)}%</p>}
        </div>
    );
}


