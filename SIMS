from metrics_collector import MetricsCollector
from gazebo_interface import GazeboClient

class EpisodeRunner:
    def __init__(self, steps_per_episode=500, num_episodes=50):
        self.steps_per_episode = steps_per_episode
        self.num_episodes = num_episodes
        self.gazebo = GazeboClient()

    async def run_episode(self, episode_id: int):
        await self.gazebo.reset_world()
        collector = MetricsCollector(f"episode_{episode_id}")
        for step in range(self.steps_per_episode):
            state = await self.gazebo.get_robot_state()
            collector.record(state)
            await asyncio.sleep(0)
        return collector.aggregate()

    async def run_all_episodes(self):
        tasks = [self.run_episode(i) for i in range(self.num_episodes)]
        results = await asyncio.gather(*tasks)
        return results


