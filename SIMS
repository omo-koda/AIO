#!/usr/bin/env python3
# multi_robot_manager.py
# Simple orchestrator to coordinate veil rollout across multiple robot nodes via ROS2 topics.

import rclpy
from rclpy.node import Node
from std_msgs.msg import String
import json
import time
import logging
from typing import List, Dict

logger = logging.getLogger("MultiRobotManager")
if not logger.handlers:
    ch = logging.StreamHandler()
    fmt = logging.Formatter('%(asctime)s - %(levelname)s - %(message)s')
    ch.setFormatter(fmt)
    logger.addHandler(ch)
logger.setLevel(logging.INFO)

"""
Protocol (simple):
- Manager publishes rollout plan JSON to topic '/veil_rollout/control'
- Robot nodes subscribe and reply on '/veil_rollout/ack/<robot_id>'
- Manager waits for quorum/acks then sends 'apply' command
- If any robot reports 'anomaly' after apply, manager issues 'rollback' to all
"""

class MultiRobotManager(Node):
    def __init__(self, robot_ids: List[str], quorum: int = None, timeout: float = 10.0):
        super().__init__('multi_robot_manager')
        self.robot_ids = robot_ids
        self.quorum = quorum or len(robot_ids)
        self.timeout = timeout
        self.ctrl_pub = self.create_publisher(String, '/veil_rollout/control', 10)
        # subscribe to ack channel
        self.create_subscription(String, '/veil_rollout/ack', self.ack_callback, 10)
        self.acks: Dict[str, Dict] = {}
        logger.info(f"MultiRobotManager serving robots: {robot_ids}")

    def ack_callback(self, msg: String):
        try:
            payload = json.loads(msg.data)
            robot = payload.get("robot_id")
            self.acks[robot] = payload
            logger.info(f"Received ack from {robot}: {payload.get('status')}")
        except Exception:
            logger.exception("Malformed ack received")

    def broadcast_plan(self, plan: Dict):
        msg = String()
        msg.data = json.dumps(plan)
        self.ctrl_pub.publish(msg)
        logger.info("Broadcasted rollout plan")

    def wait_for_quorum(self, start_time: float) -> bool:
        deadline = start_time + self.timeout
        while time.time() < deadline:
            ready = len([r for r in self.acks.values() if r.get('status') == 'ready'])
            if ready >= self.quorum:
                return True
            time.sleep(0.2)
        return False

    def apply_rollout(self, plan: Dict) -> bool:
        # Step 1: broadcast plan (prepare)
        self.broadcast_plan({"type":"prepare", "plan": plan, "timestamp": time.time()})
        t0 = time.time()
        if not self.wait_for_quorum(t0):
            logger.error("Quorum not achieved for rollout, aborting")
            return False
        # Step 2: send apply
        self.broadcast_plan({"type":"apply", "plan": plan, "timestamp": time.time()})
        # wait for result a bit
        time.sleep(plan.get("validation_wait", 2.0))
        # check acks for anomalies
        anomalies = [a for a in self.acks.values() if a.get("status") == "anomaly"]
        if anomalies:
            logger.warn("Anomalies detected after apply — issuing rollback")
            self.broadcast_plan({"type":"rollback", "plan": plan, "timestamp": time.time()})
            return False
        logger.info("Rollout completed successfully")
        return True

def main(args=None):
    rclpy.init(args=args)
    manager = MultiRobotManager(robot_ids=["robotA","robotB"])
    # example plan
    plan = {"start_idx":0, "batch_size":50, "veil_file":"veils_1_50.json", "validation_wait":3.0}
    success = manager.apply_rollout(plan)
    logger.info(f"Rollout success: {success}")
    rclpy.shutdown()


