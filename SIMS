# backend/app/enhanced_veil_loader.py
import torch, os, time, json, logging
from typing import List, Dict, Any, Callable

logger = logging.getLogger("EnhancedVeilLoader")
if not logger.handlers:
    ch = logging.StreamHandler()
    ch.setFormatter(logging.Formatter('%(asctime)s - %(levelname)s - %(message)s'))
    logger.addHandler(ch)
logger.setLevel(logging.INFO)

class EnhancedVeilLoader:
    def __init__(self, model, device='cpu', batch_size=50, min_w=-1.0, max_w=1.0,
                 metrics_fn: Callable[[Any], Dict[str, float]] = None,
                 anomaly_fn: Callable[[Dict[str,float], Dict[str,float]], bool] = None,
                 audit_path: str = "data/veil_audit_log.jsonl"):
        self.model = model.to(device)
        self.device = device
        self.batch_size = batch_size
        self.min_w = min_w
        self.max_w = max_w
        self.veils: List[float] = []
        self.index = 0
        self.metrics_fn = metrics_fn or (lambda m: {"stability": 1.0, "safety": 1.0, "efficiency": 1.0, "samples":0})
        self.anomaly_fn = anomaly_fn or (lambda pre, post: False)
        self.audit_log_path = audit_path
        os.makedirs(os.path.dirname(self.audit_log_path), exist_ok=True)
        self.last_apply_time = None
        self.applied_batches = 0

    def load_from_json(self, filepath: str) -> bool:
        if not os.path.exists(filepath):
            logger.error("Veil file missing: %s", filepath)
            return False
        with open(filepath, 'r') as f:
            data = json.load(f)
        vals = []
        if isinstance(data, dict):
            for k in sorted(data.keys()):
                v = data[k]
                if isinstance(v, list):
                    vals.extend([float(x) for x in v])
                else:
                    vals.append(float(v))
        elif isinstance(data, list):
            vals = [float(x) for x in data]
        else:
            logger.error("Unsupported veil format")
            return False
        self.veils = vals
        self.index = 0
        logger.info("Loaded %d veil values from %s", len(self.veils), filepath)
        return True

    def _clamp(self, arr: List[float]) -> List[float]:
        return [max(self.min_w, min(self.max_w, float(x))) for x in arr]

    def _snapshot_params(self) -> Dict[str, Any]:
        return {f"p{i}": p.detach().cpu().flatten().tolist()[:16] for i,p in enumerate(self.model.parameters())}

    def _append_audit(self, record: Dict[str, Any]):
        try:
            with open(self.audit_log_path, 'a') as f:
                f.write(json.dumps(record) + "\n")
        except Exception:
            logger.exception("Failed to write audit log")

    def apply_next(self) -> bool:
        if not self.veils or self.index >= len(self.veils):
            logger.info("No more veils to apply")
            return False
        start = self.index
        end = min(self.index + self.batch_size, len(self.veils))
        batch = self._clamp(self.veils[start:end])

        pre = self.metrics_fn(self.model)
        pre_state = self._snapshot_params()
        try:
            logger.info("Applying veil batch %d:%d", start, end)
            # snapshot model parameters (model must implement snapshot_state)
            if hasattr(self.model, "snapshot_state"):
                self.model.snapshot_state()
            # apply weights atomically using model API
            self.model.set_veil_weights(batch, start_index=start)
        except Exception:
            logger.exception("Failed to set veil weights - attempting restore")
            try:
                if hasattr(self.model, "restore_snapshot"):
                    self.model.restore_snapshot()
            except Exception:
                logger.exception("Restore failed")
            return False

        t0 = time.time()
        post = self.metrics_fn(self.model)
        apply_time = time.time() - t0
        self.last_apply_time = apply_time
        self.applied_batches += 1

        anomaly = False
        try:
            anomaly = self.anomaly_fn(pre, post)
        except Exception:
            logger.exception("Anomaly function error - treating as anomaly")
            anomaly = True

        record = {
            "timestamp": time.time(),
            "start": start,
            "end": end,
            "applied_time": apply_time,
            "pre_metrics": pre,
            "post_metrics": post,
            "anomaly": anomaly
        }
        self._append_audit(record)

        if anomaly:
            logger.warning("Anomaly detected after batch - rolling back")
            try:
                self.model.rollback_veil_weights()
            except Exception:
                logger.exception("Rollback failed")
                return False
            return False
        else:
            self.index = end
            logger.info("Veil batch applied successfully, new index %d", self.index)
            return True

    def adaptive_timeout(self, base_timeout: float = 0.1) -> float:
        if self.applied_batches == 0 or self.last_apply_time is None:
            return base_timeout
        avg = max(self.last_apply_time, 1e-6)
        scale = min(5.0, 1.0 + avg / base_timeout)
        return base_timeout * scale

    def all_applied(self) -> bool:
        return self.index >= len(self.veils)


