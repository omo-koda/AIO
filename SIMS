        ok = self.loader.load_from_json(path)
        return ok

    def apply_next(self):
        ok = self.loader.apply_next()
        if self.telemetry:
            import asyncio
            asyncio.create_task(self.telemetry.publish({"event":"veil_apply","ok":ok}))
        return ok

    def rollback(self):
        try:
            self.model.rollback_veil_weights()
            return True
        except Exception:
            logger.exception("rollback fail")
            return False


