#!/usr/bin/env python3
# enhanced_controller.py
# Production-ready ROS2 controller with sensor validation, network failure handling, and diagnostics.

import rclpy
from rclpy.node import Node
from std_msgs.msg import Float64MultiArray
from sensor_msgs.msg import JointState
from geometry_msgs.msg import Twist
import time
import logging
import traceback
from typing import List, Dict, Any

import torch
import torch.nn as nn

# -------------------------
# Logging setup (structured)
# -------------------------
logger = logging.getLogger("EnhancedController")
if not logger.handlers:
    ch = logging.StreamHandler()
    formatter = logging.Formatter('%(asctime)s - %(levelname)s - %(name)s - %(message)s')
    ch.setFormatter(formatter)
    logger.addHandler(ch)
logger.setLevel(logging.INFO)

# -------------------------
# Safety configuration
# -------------------------
EMERGENCY_STOP_TIMEOUT_BASE = 0.1  # base seconds (100ms)
JOINT_LIMITS = {'joint_1': (-1.57, 1.57), 'joint_2': (-1.0, 1.0), 'joint_3': (-2.0, 2.0)}
COLLISION_THRESHOLD = 0.05  # meters
SENSOR_MAX_RANGE = 10.0  # meters (example)
SENSOR_MIN_RANGE = 0.001
SENSOR_STALE_TIMEOUT = 0.5  # seconds

# -------------------------
# VeilNet skeleton with failure handling hooks
# -------------------------
class VeilNet(nn.Module):
    def __init__(self, input_size=3, hidden_size=64, output_size=3):
        super().__init__()
        self.fc1 = nn.Linear(input_size, hidden_size)
        self.ln1 = nn.LayerNorm(hidden_size)
        self.fc2 = nn.Linear(hidden_size, hidden_size)
        self.ln2 = nn.LayerNorm(hidden_size)
        self.fc3 = nn.Linear(hidden_size, output_size)
        self.device = torch.device("cpu")
        self.fail_safe_output = torch.zeros(output_size, dtype=torch.float32)
        self._last_good_state = None

    def forward(self, x):
        x = torch.relu(self.ln1(self.fc1(x)))
        x = torch.relu(self.ln2(self.fc2(x)))
        return self.fc3(x)

    # Failure-safe interface
    def snapshot_state(self):
        self._last_good_state = [p.detach().cpu().clone() for p in self.parameters()]

    def restore_snapshot(self):
        if self._last_good_state is not None:
            for p, saved in zip(self.parameters(), self._last_good_state):
                p.data.copy_(saved.to(p.device))
            return True
        return False

    def safe_infer(self, x):
        """Wrap inference in try/except and return fail-safe output on failure"""
        try:
            with torch.no_grad():
                return self.forward(x.to(self.device)).cpu()
        except Exception:
            logger.exception("Model inference failure — returning fail-safe output")
            return self.fail_safe_output

# -------------------------
# Helper validation
# -------------------------
def validate_sensor_readings(readings: List[float]) -> bool:
    """Validate list of scalar distance readings for sanity and freshness."""
    if readings is None or len(readings) == 0:
        logger.warning("Sensor validation: empty readings")
        return False
    for v in readings:
        if not isinstance(v, (int, float)):
            logger.warning(f"Sensor validation: non-numeric value {v}")
            return False
        if v != v:  # NaN
            logger.warning("Sensor validation: NaN value detected")
            return False
        if v < SENSOR_MIN_RANGE or v > SENSOR_MAX_RANGE:
            logger.warning(f"Sensor validation: out-of-range value {v}")
            return False
    return True

# -------------------------
# Controller Node
# -------------------------
class EnhancedController(Node):
    def __init__(self):
        super().__init__('enhanced_controller')
        self.joint_pub = self.create_publisher(Float64MultiArray, 'joint_commands', 10)
        self.cmd_vel_pub = self.create_publisher(Twist, 'cmd_vel', 10)
        self.create_subscription(JointState, 'joint_states', self.joint_callback, 10)
        self.create_subscription(Float64MultiArray, 'sensor_distance', self.sensor_callback, 10)

        self.last_command_time = time.time()
        self.emergency_stopped = False
        self.joint_positions: Dict[str, float] = {}
        self.sensor_distances: List[float] = []
        self.sensor_timestamp = 0.0

        # Model
        self.model = VeilNet(input_size=len(JOINT_LIMITS), hidden_size=64, output_size=len(JOINT_LIMITS))
        self.model.device = torch.device("cpu")
        self.model.eval()
        self.model.snapshot_state()

        # Adaptive emergency timeout state (will be updated by monitor)
        self.emergency_timeout = EMERGENCY_STOP_TIMEOUT_BASE
        self.timer = self.create_timer(0.02, self.control_loop)  # 50 Hz
        self.monitor_timer = self.create_timer(1.0, self.adaptive_monitor)  # 1 Hz
        logger.info("EnhancedController initialized")

    # Callbacks
    def joint_callback(self, msg: JointState):
        for name, pos in zip(msg.name, msg.position):
            self.joint_positions[name] = pos

    def sensor_callback(self, msg: Float64MultiArray):
        try:
            data = list(msg.data)
            if validate_sensor_readings(data):
                self.sensor_distances = data
                self.sensor_timestamp = time.time()
            else:
                logger.warning("Sensor callback validation failed")
        except Exception:
            logger.exception("Exception processing sensor_callback")

    # Safety checks
    def check_emergency_stop(self):
        elapsed = time.time() - self.last_command_time
        if elapsed > self.emergency_timeout:
            if not self.emergency_stopped:
                logger.warn(f"Emergency stop triggered: elapsed {elapsed:.3f}s > timeout {self.emergency_timeout:.3f}s")
            self.emergency_stopped = True
            return True
        self.emergency_stopped = False
        return False

    def check_joint_limits(self, commands: List[float]) -> List[float]:
        safe = []
        for (k, (mn, mx)), cmd in zip(JOINT_LIMITS.items(), commands):
            clamped = max(min(cmd, mx), mn)
            safe.append(clamped)
            if clamped != cmd:
                logger.debug(f"Command for {k} clamped {cmd} -> {clamped}")
        return safe

    def check_collisions(self) -> bool:
        if self.sensor_distances and (time.time() - self.sensor_timestamp) < SENSOR_STALE_TIMEOUT:
            if any(d < COLLISION_THRESHOLD for d in self.sensor_distances):
                logger.warn("Collision threshold breached by sensors")
                return True
            return False
        else:
            logger.warn("Sensor data stale or missing — treating as potential hazard")
            return True  # Conservative: treat stale/missing sensor as hazard

    # Control loop
    def control_loop(self):
        try:
            if self.check_emergency_stop():
                self.publish_stop()
                return

            if self.check_collisions():
                self.publish_stop()
                return

            if len(self.joint_positions) < len(JOINT_LIMITS):
                # waiting for full joint state
                return

            # Prepare input tensor (consistent ordering)
            joint_values = torch.tensor([self.joint_positions[k] for k in JOINT_LIMITS.keys()], dtype=torch.float32)
            # Safe inference
            out = self.model.safe_infer(joint_values)
            safe_cmds = self.check_joint_limits(out.tolist())
            msg = Float64MultiArray()
            msg.data = safe_cmds
            self.joint_pub.publish(msg)
            self.last_command_time = time.time()
        except Exception:
            logger.exception("Unexpected error in control_loop — publishing stop")
            self.publish_stop()

    def publish_stop(self):
        stop_msg = Float64MultiArray()
        stop_msg.data = [0.0 for _ in JOINT_LIMITS]
        self.joint_pub.publish(stop_msg)

    # Monitor & adaptive logic
    def adaptive_monitor(self):
        """
        Example adaptive logic: adjust emergency timeout based on recent inference latency.
        This is an example; replace with more robust measurements if desired.
        """
        # Placeholder: simple smoothing logic (in production measure real latencies)
        # For now keep base timeout
        self.emergency_timeout = EMERGENCY_STOP_TIMEOUT_BASE

def main(args=None):
    rclpy.init(args=args)
    node = EnhancedController()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        logger.info("Shutting down EnhancedController")
    finally:
        node.destroy_node()
        rclpy.shutdown()


