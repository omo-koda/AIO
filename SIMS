# backend/app/main.py
from fastapi import FastAPI, WebSocket, UploadFile, File, BackgroundTasks
from fastapi.responses import JSONResponse
import asyncio, os, time
from .telemetry_server import TelemetryHub
from .veil_service import VeilService
from .episode_runner import EpisodeRunner

app = FastAPI(title="SimaaS-Veil Backend")
telemetry = TelemetryHub()
veil_service = VeilService(telemetry=telemetry)
episode_runner = EpisodeRunner(telemetry=telemetry, veil_service=veil_service)

@app.get("/")
async def root():
    return {"service":"simaas-veil backend", "status":"ok"}

@app.websocket("/ws/state")
async def ws_state(ws: WebSocket):
    await telemetry.websocket_handler(ws)

@app.post("/veil/upload")
async def upload_veil(file: UploadFile = File(...)):
    path = f"data/veils/{int(time.time())}_{file.filename}"
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "wb") as f:
        f.write(await file.read())
    ok = veil_service.load_from_file(path)
    return JSONResponse({"loaded": ok, "path": path})

@app.post("/veil/apply")
async def apply_next():
    ok = veil_service.apply_next()
    return JSONResponse({"applied": ok})

@app.post("/veil/rollback")
async def rollback():
    ok = veil_service.rollback()
    return JSONResponse({"rolled_back": ok})

@app.post("/episodes/run")
async def run_episodes(background: BackgroundTasks, num_episodes: int = 20):
    background.add_task(lambda: asyncio.run(episode_runner.run_all(num_episodes)),)
    return JSONResponse({"started": True, "episodes": num_episodes})


