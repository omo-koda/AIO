#!/usr/bin/env python3
"""
Episode Runner for Unitree Veil Integration
Author: Bínò ÈL Guà
Description: Automates simulation episodes in Gazebo, collects metrics, builds baselines, and integrates with Veil loader.
"""

import rclpy
from rclpy.node import Node
from std_srvs.srv import Empty
import time
import yaml
import json
import os

# === Import your metrics framework ===
from metrics_framework import MetricsCollector, BaselineBuilder, VeilLoader

class EpisodeRunner(Node):
    def __init__(self):
        super().__init__('episode_runner')
        
        # Load configuration
        config_path = os.path.join(os.path.dirname(__file__), 'episode_config.yaml')
        with open(config_path, 'r') as f:
            self.config = yaml.safe_load(f)
        
        # ROS2 Service clients for Gazebo control
        self.reset_world_client = self.create_client(Empty, '/reset_world')
        self.pause_sim_client = self.create_client(Empty, '/pause_physics')
        self.unpause_sim_client = self.create_client(Empty, '/unpause_physics')

        # Initialize MetricsCollector, BaselineBuilder, VeilLoader
        self.metrics = MetricsCollector()
        self.baseline = BaselineBuilder()
        self.veil = VeilLoader()

        self.num_episodes = self.config.get('num_episodes', 20)
        self.episode_duration = self.config.get('episode_duration', 60)  # seconds
        self.output_dir = self.config.get('output_dir', 'episode_data')
        os.makedirs(self.output_dir, exist_ok=True)

    def call_service(self, client):
        while not client.wait_for_service(timeout_sec=1.0):
            self.get_logger().info('Waiting for service...')
        req = Empty.Request()
        return client.call_async(req)

    def run_episode(self, episode_idx):
        self.get_logger().info(f'=== Starting Episode {episode_idx} ===')
        
        # Reset Gazebo world
        self.call_service(self.reset_world_client)
        time.sleep(1.0)  # ensure reset completes

        # Unpause simulation
        self.call_service(self.unpause_sim_client)
        
        # Start metrics collection
        self.metrics.start_episode()

        start_time = time.time()
        while time.time() - start_time < self.episode_duration:
            rclpy.spin_once(self, timeout_sec=0.1)
            self.metrics.collect_step()
        
        # Pause simulation
        self.call_service(self.pause_sim_client)

        # End metrics collection
        episode_metrics = self.metrics.end_episode()
        metrics_file = os.path.join(self.output_dir, f'episode_{episode_idx:03d}.json')
        with open(metrics_file, 'w') as f:
            json.dump(episode_metrics, f, indent=2)
        self.get_logger().info(f'Episode {episode_idx} metrics saved to {metrics_file}')
        
        return episode_metrics

    def run(self):
        all_metrics = []
        for i in range(self.num_episodes):
            metrics = self.run_episode(i + 1)
            all_metrics.append(metrics)

        # Build baseline from collected episodes
        self.get_logger().info('=== Building baseline from collected episodes ===')
        self.baseline.build(all_metrics)
        baseline_file = os.path.join(self.output_dir, 'baseline.json')
        self.baseline.save(baseline_file)
        self.get_logger().info(f'Baseline saved to {baseline_file}')

        # Optional: validate Veil on baseline episodes
        self.get_logger().info('=== Validating Veil configurations ===')
        self.veil.validate(all_metrics)
        self.get_logger().info('Veil validation completed.')

def main(args=None):
    rclpy.init(args=args)
    runner = EpisodeRunner()
    runner.run()
    rclpy.shutdown()

if __name__ == '__main__':
    main()


