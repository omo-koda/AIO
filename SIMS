    def set_veil_weights(self, batch: List[float], start_index:int=0):
        """Apply a flat list of floats as veil weights sequentially to model params"""
        params = list(self.parameters())
        idx = start_index
        for p in params:
            numel = p.numel()
            if idx + numel > len(batch):
                raise ValueError("Not enough data in batch to fill veil weights")
            p.data.copy_(torch.tensor(batch[idx:idx+numel], dtype=p.dtype).view_as(p))
            idx += numel
        return idx

    def snapshot_state(self):
        self._veil_state_snap = [p.detach().cpu().clone() for p in self.parameters()]

    def rollback_veil_weights(self):
        if self._veil_state_snap is None:
            return False
        for p, snap in zip(self.parameters(), self._veil_state_snap):
            p.data.copy_(snap.to(p.device))
        return True


