import rclpy
from rclpy.node import Node
from sensor_msgs.msg import JointState
from std_msgs.msg import Float64MultiArray
import yaml

class EnhancedController(Node):
    def __init__(self):
        super().__init__('enhanced_controller')

        # Load joint limits
        with open('config/joint_limits.yaml', 'r') as f:
            self.joint_limits = yaml.safe_load(f)

        # Publishers and subscribers
        self.pub = self.create_publisher(Float64MultiArray, 'joint_commands', 10)
        self.sub = self.create_subscription(JointState, 'joint_states', self.joint_state_cb, 10)

    def joint_state_cb(self, msg: JointState):
        # Add safety checks
        positions = []
        for i, name in enumerate(msg.name):
            val = msg.position[i]
            min_limit = self.joint_limits[name]['min']
            max_limit = self.joint_limits[name]['max']
            val = max(min(val, max_limit), min_limit)
            positions.append(val)
        # Publish safe command
        cmd = Float64MultiArray(data=positions)
        self.pub.publish(cmd)

def main(args=None):
    rclpy.init(args=args)
    node = EnhancedController()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()


