# backend/app/episode_runner.py
import asyncio, os, time, json
from .gazebo_interface import GazeboClient
from .metrics_collector import MetricsCollector, BaselineBuilder

class EpisodeRunner:
    def __init__(self, telemetry=None, veil_service=None):
        self.gazebo = GazeboClient()
        self.telemetry = telemetry
        self.veil_service = veil_service
        self.output_dir = "data/simulation_runs"
        os.makedirs(self.output_dir, exist_ok=True)

    async def run_one(self, idx, episode_duration=30, step_dt=0.05):
        await self.gazebo.reset_world()
        collector = MetricsCollector(f"episode_{idx}")
        start=time.time()
        while time.time()-start < episode_duration:
            state = await self.gazebo.get_robot_state()
            collector.record(state)
            if self.telemetry:
                await self.telemetry.publish({"type":"state","episode":idx,"state":state})
            await asyncio.sleep(step_dt)
        agg = collector.aggregate()
        with open(f"{self.output_dir}/episode_{idx}.json","w") as f:
            json.dump(agg,f)
        return agg

    async def run_all(self, num_episodes=20, parallel=4):
        results=[]
        sem = asyncio.Semaphore(parallel)
        async def run_with_sem(i):
            async with sem:
                return await self.run_one(i)
        tasks = [asyncio.create_task(run_with_sem(i+1)) for i in range(num_episodes)]
        for t in tasks:
            results.append(await t)
        bb = BaselineBuilder()
        for r in results:
            bb.add_episode(r)
        baseline_path = "data/baseline.json"
        bb.save(baseline_path)
        if self.telemetry:
            await self.telemetry.publish({"type":"baseline","path":baseline_path})
        return results


