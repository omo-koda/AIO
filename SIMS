#!/usr/bin/env python3
import rclpy, time, json, logging
from rclpy.node import Node
from std_msgs.msg import String
logger = logging.getLogger("MultiRobotManager")
if not logger.handlers:
    ch = logging.StreamHandler()
    ch.setFormatter(logging.Formatter('%(asctime)s - %(levelname)s - %(message)s'))
    logger.addHandler(ch)
logger.setLevel(logging.INFO)

class MultiRobotManager(Node):
    def __init__(self, robot_ids=None, quorum=None, timeout=10.0):
        super().__init__('multi_robot_manager')
        self.robot_ids = robot_ids or []
        self.quorum = quorum or len(self.robot_ids)
        self.timeout = timeout
        self.ctrl_pub = self.create_publisher(String, '/veil_rollout/control', 10)
        self.create_subscription(String, '/veil_rollout/ack', self.ack_callback, 10)
        self.acks = {}
        self.get_logger().info(f"Manager for robots: {self.robot_ids}")

    def ack_callback(self, msg):
        try:
            payload = json.loads(msg.data)
            robot = payload.get("robot_id")
            self.acks[robot] = payload
        except Exception:
            self.get_logger().exception("Malformed ack")

    def broadcast_plan(self, plan):
        msg = String()
        msg.data = json.dumps(plan)
        self.ctrl_pub.publish(msg)
        self.get_logger().info("Broadcasted plan")

    def wait_for_quorum(self, start_time):
        deadline = start_time + self.timeout
        while time.time() < deadline:
            ready = len([r for r in self.acks.values() if r.get('status') == 'ready'])
            if ready >= self.quorum:
                return True
            time.sleep(0.2)
        return False

    def apply_rollout(self, plan):
        self.broadcast_plan({"type":"prepare","plan":plan,"timestamp":time.time()})
        t0 = time.time()
        if not self.wait_for_quorum(t0):
            self.get_logger().error("Quorum not achieved")
            return False
        self.broadcast_plan({"type":"apply","plan":plan,"timestamp":time.time()})
        time.sleep(plan.get("validation_wait",2.0))
        anomalies = [a for a in self.acks.values() if a.get("status") == "anomaly"]
        if anomalies:
            self.broadcast_plan({"type":"rollback","plan":plan,"timestamp":time.time()})
            return False
        self.get_logger().info("Rollout success")
        return True

def main(args=None):
    rclpy.init(args=args)
    manager = MultiRobotManager(robot_ids=["unitree_1","unitree_2"])
    plan = {"start_idx":0,"batch_size":50,"veil_file":"veils_1_50.json","validation_wait":3.0}
    ok = manager.apply_rollout(plan)
    manager.get_logger().info(f"Rollout success: {ok}")
    rclpy.shutdown()


