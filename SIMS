#!/usr/bin/env python3
# enhanced_veil_loader.py
# Veil loader with metrics, anomaly detection, auditing, and adaptive timeout feedback.

import torch
import os
import time
import json
import logging
from typing import List, Dict, Any, Callable

logger = logging.getLogger("EnhancedVeilLoader")
if not logger.handlers:
    ch = logging.StreamHandler()
    fmt = logging.Formatter('%(asctime)s - %(levelname)s - %(message)s')
    ch.setFormatter(fmt)
    logger.addHandler(ch)
logger.setLevel(logging.INFO)

class EnhancedVeilLoader:
    def __init__(self, model, device='cpu', batch_size=50, min_w=-1.0, max_w=1.0,
                 metrics_fn: Callable[[Any], Dict[str, float]] = None,
                 anomaly_fn: Callable[[Dict[str,float], Dict[str,float]], bool] = None):
        """
        metrics_fn(model) -> dict of numeric metrics (pre/post)
        anomaly_fn(pre_metrics, post_metrics) -> True if anomaly detected
        """
        self.model = model.to(device)
        self.device = device
        self.batch_size = batch_size
        self.min_w = min_w
        self.max_w = max_w
        self.veils = []
        self.index = 0
        self.metrics_fn = metrics_fn or (lambda m: {"dummy": 1.0})
        self.anomaly_fn = anomaly_fn or (lambda pre, post: False)
        self.audit_log_path = "data/veil_audit_log.jsonl"
        os.makedirs(os.path.dirname(self.audit_log_path), exist_ok=True)
        # Adaptive timing stats
        self.last_apply_time = None
        self.applied_batches = 0

    def load_from_json(self, filepath: str) -> bool:
        if not os.path.exists(filepath):
            logger.error(f"Veil file missing: {filepath}")
            return False
        with open(filepath, 'r') as f:
            data = json.load(f)
        # Expect list of floats or dict->values
        if isinstance(data, dict):
            # sort by key to have deterministic order
            keys = sorted(data.keys())
            vals = []
            for k in keys:
                v = data[k]
                if isinstance(v, (list, tuple)):
                    vals.extend(v)
                else:
                    vals.append(float(v))
            self.veils = vals
        elif isinstance(data, list):
            self.veils = [float(x) for x in data]
        else:
            logger.error("Unsupported veil file format")
            return False
        self.index = 0
        logger.info(f"Loaded {len(self.veils)} veil values")
        return True

    def _clamp(self, arr: List[float]) -> List[float]:
        return [max(self.min_w, min(self.max_w, float(x))) for x in arr]

    def apply_next(self) -> bool:
        if not self.veils or self.index >= len(self.veils):
            logger.info("No more veils to apply")
            return False
        start = self.index
        end = min(self.index + self.batch_size, len(self.veils))
        batch = self._clamp(self.veils[start:end])

        # Pre metrics
        pre = self.metrics_fn(self.model)
        pre_state = self._snapshot_params()

        t0 = time.time()
        try:
            # Use model interface contract: set_veil_weights(batch, start_index)
            logger.info(f"Applying veil batch {start}:{end}")
            self.model.set_veil_weights(batch, start_index=start)
            self.model.snapshot_state()
        except Exception:
            logger.exception("Failed to set veil weights - attempting restore")
            self.model.restore_snapshot()
            return False

        apply_time = time.time() - t0
        self.last_apply_time = apply_time
        self.applied_batches += 1

        # Post metrics & anomaly detection
        post = self.metrics_fn(self.model)
        anomaly = False
        try:
            anomaly = self.anomaly_fn(pre, post)
        except Exception:
            logger.exception("Anomaly detection function raised an error; treating as anomaly")
            anomaly = True

        # Audit log (structured)
        record = {
            "timestamp": time.time(),
            "start": start,
            "end": end,
            "applied_time": apply_time,
            "pre_metrics": pre,
            "post_metrics": post,
            "anomaly": anomaly
        }
        self._append_audit(record)

        if anomaly:
            logger.warning("Anomaly detected after applying veil batch; rolling back")
            try:
                self.model.rollback_veil_weights()
            except Exception:
                logger.exception("Rollback failed")
                return False
            # do not advance index
            return False
        else:
            self.index = end
            # update adaptive timeout feedback if needed by caller; return True
            return True

    def adaptive_timeout(self, base_timeout: float = 0.1) -> float:
        """
        Calculate an adaptive timeout: simple heuristic that increases timeout
        modestly with average apply time.
        """
        if self.applied_batches == 0 or self.last_apply_time is None:
            return base_timeout
        avg = max(self.last_apply_time, 1e-6)
        # scale factor: keep it small — never exceed 5x base by default
        scale = min(5.0, 1.0 + avg / base_timeout)
        return base_timeout * scale

    def _snapshot_params(self) -> Dict[str, List[float]]:
        """Return a shallow snapshot of current parameters for the audit log"""
        return {f"p{i}": p.detach().cpu().flatten().tolist()[:16] for i, p in enumerate(self.model.parameters())}

    def _append_audit(self, record: Dict[str, Any]):
        try:
            with open(self.audit_log_path, 'a') as f:
                f.write(json.dumps(record) + "\n")
        except Exception:
            logger.exception("Failed to write audit log")


