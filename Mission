import { CustodyAdapter } from "./types";
import { OsoRpcAdapter } from "./adapters/osoRpc";
import { SafeAdapter } from "./adapters/safe";
import { DryRunAdapter } from "./adapters/dryRun";

export function makeCustodyAdapter(): CustodyAdapter {
  const key = (process.env.CUSTODY_ADAPTER ?? "dry-run").toLowerCase();
  switch (key) {
    case "oso": return new OsoRpcAdapter({
      rpcUrl: process.env.OSO_RPC_URL ?? "",
      routerAddr: process.env.OSO_ROUTER_ADDR ?? "",
      signerKey: process.env.OSO_SIGNER_KEY ?? ""
    });
    case "safe": return new SafeAdapter({
      rpcUrl: process.env.SAFE_RPC_URL ?? "",
      safeAddress: process.env.SAFE_ADDRESS ?? "",
      signerKey: process.env.SAFE_SIGNER_KEY ?? ""
    });
    default: return new DryRunAdapter();
  }
}

