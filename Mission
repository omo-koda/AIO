import { tithePauseUntil } from "../metrics";

const ESU_TITHE_BPS = Number(process.env.ESU_TITHE_BPS ?? 369);
const PAUSED_UNTIL = Number(process.env.ESU_TITHE_PAUSED_UNTIL_EPOCH ?? 0);
tithePauseUntil.set(PAUSED_UNTIL);

function nowSeconds() { return Math.floor(Date.now() / 1000); }

function bps(amount: bigint, rate: number) {
  return (amount * BigInt(rate)) / 10000n;
}

export function applyEsuTithe(grossAse: bigint) {
  if (nowSeconds() < PAUSED_UNTIL) {
    return { tithe: 0n, net: grossAse };
  }
  const tithe = bps(grossAse, ESU_TITHE_BPS);
  const net = grossAse - tithe;
  return { tithe, net };
}

> Pauses are visible in Prometheus and your alert will fire if the pause overruns.




