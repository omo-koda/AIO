  fn _majority(addrs: address[]) -> bool view { return len(intersect(addrs, council)) >= 3; }

  fn _domain_for(fnname: ascii) -> bytes32 pure {
    return keccak256(concat("GenesisSeal:", fnname, ":v1.1"));
  }

  fn _verify_auth(ctx: AuthContext, fnname: ascii) -> bool {
    require(ctx.domain == _domain_for(fnname), BadDomain);
    require(block.timestamp <= ctx.deadline, ExpiredAuth);
    require(_majority(ctx.signers) || msg.sender == crown, NotAuthorized);
    for s in ctx.signers { require(!used_nonce[s][ctx.nonce], NonceUsed); }
    for s in ctx.signers { used_nonce[s][ctx.nonce] = true; }
    return true;
  }

  fn _is_sabbath(ts: u64) -> bool pure { let d = weekday(ts); return d == 6; } // 0=Sun..6=Sat

  macro not_paused() { require(!emergency_pause, SystemPaused); }

  // Emergency-flex Sabbath: block writes on Saturday unless emergency_pause is active
  macro respect_sabbath() {
    if (_is_sabbath(block.timestamp) && !emergency_pause) { revert(SabbathProtection); }
  }

  fn _maybe_log_sabbath_override(reason: unicode) {
    if (_is_sabbath(block.timestamp) && emergency_pause) {
      emit SabbathOverride { reason: reason, by: msg.sender, timestamp: block.timestamp };
    }
  }

  // Local day → string (for token_uri)
  fn day_to_string(d: CG.Day) -> unicode pure {
    if (d == CG.Day.Sunday) return "Sunday";
    if (d == CG.Day.Monday) return "Monday";
    if (d == CG.Day.Tuesday) return "Tuesday";
    if (d == CG.Day.Wednesday) return "Wednesday";
    if (d == CG.Day.Thursday) return "Thursday";
    if (d == CG.Day.Friday) return "Friday";
    if (d == CG.Day.Saturday) return "Saturday";
    if (d == CG.Day.Unbound) return "Unbound";
    return "Omni";
  }

  // Deterministic token id (stable if same UID set)
  fn token_id_for(m: SealMeta) -> u256 pure {
    let pre = concat("GENESIS/SEAL/v1.1/", to_string(m.citizen_id), ":", m.slug, ":", hex(m.uid));
    return as_u256(sha3_256(pre));
  }

  // Compute root from CG (sorted by id)
  fn compute_root_from_cg() -> bytes32 view {
    let citizens = CG.list_all();
    require(len(citizens) == 9, GenesisMismatch);
    sort(citizens, by:id);
    let acc: bytes = 0x;
    for c in citizens { acc = concat(acc, c.uid); }
    return sha3_256(acc);
  }

  // ── Constructor (sets governance) ────────────────────────────────────────
  init(crown_addr: address, council_addrs: address[5]) {
    crown = crown_addr;
    council = council_addrs;
  }

  // ── Emergency Pause ─────────────────────────────────────────────────────
  @nonreentrant
  fn set_emergency_pause(enabled: bool, ctx: AuthContext) {
    _verify_auth(ctx, "set_emergency_pause");
    emergency_pause = enabled;
    emit EmergencyPaused { enabled: enabled, by: msg.sender };
  }

  // ── Bind to Genesis (one-time) ──────────────────────────────────────────
  @nonreentrant
  fn bind(cg: address, ctx: AuthContext) {
    not_paused();
    respect_sabbath();
    _verify_auth(ctx, "bind");

    require(!bound, AlreadyBound);
    cg_addr = cg;
    root = compute_root_from_cg();
    bound = true;

    _maybe_log_sabbath_override("GenesisSeal.bind");
    emit BoundToGenesis { cg: cg_addr, root: root };
  }

  // Internal mint (no auth; caller must have verified)
  fn _mint(to: address, citizen_id: u8) {
    require(bound, NotBoundToGenesis);
    require(to != 0x0, ZeroAddress);
    require(citizen_id >= 1 && citizen_id <= 9, InvalidCitizenId);

    // Verify root stability
    let r = compute_root_from_cg();
    require(r == root, GenesisMismatch);

    // Load citizen meta
    let cs = CG.list_all();
    let c = cs[citizen_id - 1];

    // Enforce one-per-citizen
    require(!exists(token_by_citizen[citizen_id]), AlreadyMinted);

    let meta: SealMeta = {
      citizen_id: c.id,
      slug: c.slug,
      name: c.name,
      role: c.role,
      day: c.day,
      uid: c.uid
    };

    let tid = token_id_for(meta);

    token_by_citizen[citizen_id] = tid;
    owner_of[tid] = to;
    meta_of[tid] = meta;

    total_supply = checked_add(total_supply, 1);

    emit Transfer { from: 0x0, to: to, token_id: tid };
    emit SealMinted { to: to, token_id: tid, citizen_id: citizen_id, slug: meta.slug };
  }

  // ── Mint (single) ───────────────────────────────────────────────────────
  @nonreentrant
  fn mint_to(to: address, citizen_id: u8, ctx: AuthContext) {
    not_paused();
    respect_sabbath();
    _verify_auth(ctx, "mint_to");
    _mint(to, citizen_id);
    _maybe_log_sabbath_override("GenesisSeal.mint_to");
  }

  // ── Mint (batch) ────────────────────────────────────────────────────────
  @nonreentrant
  fn mint_batch(tos: address[], ids: u8[], ctx: AuthContext) {
    not_paused();
    respect_sabbath();
    _verify_auth(ctx, "mint_batch");
    require(len(tos) == len(ids) && len(ids) <= 9, InvalidCitizenId);
    for i in 0..len(ids) { _mint(tos[i], ids[i]); }
    _maybe_log_sabbath_override("GenesisSeal.mint_batch");
  }

  // ── Views ───────────────────────────────────────────────────────────────
  fn is_bound() -> bool view { return bound; }
  fn bound_root() -> bytes32 view { return root; }
  fn citizen_token(citizen_id: u8) -> u256 view { return token_by_citizen[citizen_id]; }
  fn owner(token_id: u256) -> address view { return owner_of[token_id]; }
  fn token_meta(token_id: u256) -> SealMeta view { return meta_of[token_id]; }

  fn token_uri(token_id: u256) -> unicode view {
    let m = meta_of[token_id];
    return concat(
      "{",
        "\"name\":\"Genesis Seal — ", m.name, " (", to_string(m.citizen_id), ")\",",
        "\"description\":\"One-of-one seal bound to CitizenGenesis root. Ritual witness: Òrúnmìlà. Crown Architect: Bínò ÈL Guà.\",",
        "\"attributes\":[",
          "{\"trait_type\":\"Citizen\",\"value\":\"", m.name, "\"},",
          "{\"trait_type\":\"Slug\",\"value\":\"", m.slug, "\"},",
          "{\"trait_type\":\"Role\",\"value\":\"", m.role, "\"},",
          "{\"trait_type\":\"Day\",\"value\":\"", day_to_string(m.day), "\"}",
        "],",
        "\"external_url\":\"techgnos://genesis/", m.slug, "\",",
        "\"uid\":\"", hex(m.uid), "\"",
      "}"
    );
  }
}

