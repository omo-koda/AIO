tests/GenesisSeal.v1_1.spec.oso

import "../contracts/CitizenGenesis.v1_1.oso" as CG;
import "../contracts/CitizenGenesis.init.v1_1.oso" as CGI;
import "../contracts/GenesisSeal.v1_1.oso" as GS;
import "../contracts/GenesisSeal.bind.v1_1.oso" as GSB;
import "../contracts/GenesisSeal.mint9.v1_1.oso" as GSM;

fn mk_ctx(fnname: ascii, signers: address[]) -> GS.AuthContext pure {
  return {
    nonce: 777,
    deadline: block.timestamp + 9999,
    domain: keccak256(concat("GenesisSeal:", fnname, ":v1.1")),
    signers: signers
  };
}

@test
fn binds_once_and_matches_root() {
  let elders: address[] = [0xEL1,0xEL2,0xEL3];

  // Initialize genesis
  with_multisig(elders, || { CGI.init(); });

  // Bind seals
  with_multisig(elders, || { GSB.bind_now(); });
  assert_true(GS.is_bound());

  let r1 = GS.bound_root();
  let r2 = GS.compute_root_from_cg();
  assert_eq(r1, r2);

  // Second bind should fail (AlreadyBound)
  let ctx = mk_ctx("bind", elders);
  expect_revert(GS.AlreadyBound, || { GS.bind(0xDEAD, ctx); });
}

@test
fn sabbath_emergency_override_allows_actions() {
  let elders: address[] = [0xEL1,0xEL2,0xEL3];
  with_multisig(elders, || { GSB.bind_now(); });

  // Warp to Saturday (Sabbath)
  warp_to_weekday(6); // 0=Sun .. 6=Sat

  // Without emergency, should revert
  let ctxMint = mk_ctx("mint_to", elders);
  expect_revert(GS.SabbathProtection, || { GS.mint_to(0xWALLET_A, 1, ctxMint); });

  // Enable emergency (governance action allowed any day)
  let ctxPause = mk_ctx("set_emergency_pause", elders);
  GS.set_emergency_pause(true, ctxPause);

  // Now mint succeeds during Sabbath under emergency
  let ctxMint2 = mk_ctx("mint_to", elders);
  GS.mint_to(0xWALLET_A, 1, ctxMint2);
  let tid = GS.citizen_token(1);
  assert_true(tid != 0);
}

@test
fn one_per_citizen_enforced_and_batch_mint() {
  let elders: address[] = [0xEL1,0xEL2,0xEL3];
  with_multisig(elders, || { GSB.bind_now(); });

  // Batch mint remaining 2..9
  with_multisig(elders, || { GSM.mint_all(); });

  // All nine should be minted now
  for i in 1..=9 { assert_true(GS.citizen_token(i) != 0); }

  // Duplicate mint must fail
  let ctx = mk_ctx("mint_to", elders);
  expect_revert(GS.AlreadyMinted, || { GS.mint_to(0xWALLET_B, 3, ctx); });
}

@test
fn replay_protection_blocks_nonce_reuse() {
  let elders: address[] = [0xEL1,0xEL2,0xEL3];
  with_multisig(elders, || { GSB.bind_now(); });

  let ctx = mk_ctx("mint_to", elders);
  GS.mint_to(0xWALLET_X, 8, ctx);

  // Reuse same ctx.nonce must revert (NonceUsed)
  expect_revert(GS.NonceUsed, || { GS.mint_to(0xWALLET_Y, 9, ctx); });
}


