/// ─────────────────────────────────────────────────────────────────────────────
/// CitizenGenesis.v1_1.oso — First 9 Seals (secure foundation)
/// Version: 1.1 — 2025-08-22
/// Chain: ÒSỌ́VM (TechGnØŞ.EXE)
///
/// Ritual Preamble (as requested):
/// Èmi ni Bínò ÈL Guà — ọmọ Kọ́dà, aṣáájú ọ̀nà tuntun-tuntun.
/// Ọmọ àṣẹ àti àfihàn, alákóso kóòdù àti amúnibùkún ọ̀nà.
/// Mo rọ̀ mọ́ Ìtàn àti Ìrọ̀rùn, mo gbé àṣẹ sílẹ̀ nínú kóòdù àti kíkà.
/// Ẹ̀mí mi ni kóòdù. Ìrìnàjò mi ni àkọsílẹ̀. Ìlú mi ni àyíká tuntun.
/// Mo ṣí ilẹ̀ kẹrin. Mo dá àtẹ́wọgba sílẹ̀ fún gbogbo ọmọ-kẹ́yìn.
/// ─────────────────────────────────────────────────────────────────────────────

@audit(full);

enum Day { Sunday, Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, Unbound, Omni }

struct Citizen {
  id: u8,
  slug: ascii,          // ASCII-safe key (e.g., "sango")
  name: unicode,        // Display name with full diacritics (e.g., "Ṣàngó")
  role: unicode,
  day: Day,
  function: unicode,
  uid: bytes32          // sha3_256("CITIZEN/GENESIS/v1/{id}:{slug}")
}

struct AuthContext {
  nonce: u64,
  deadline: u64,
  domain: bytes32,      // keccak("CitizenGenesis:<fn>:v1.1") or similar
  signers: address[]
}

error GenesisAlreadyRun;
error NotAuthorized;
error DuplicateId;
error DuplicateSlug;
error BadDayAlignment;
error InvalidRange;
error InvalidPayload;
error ExpiredAuth;
error BadDomain;
error NonceUsed;
error SystemPaused;
error SabbathProtection;
error RotationInProgress;
error RotationNotReady;

event CitizenRegistered { id: u8, slug: ascii, name: unicode }
event CitizenGenesisSealed { total: u8, root: bytes32, hash: bytes32 }
event AccessDenied { caller: address, fn: ascii }
event EmergencyPaused { enabled: bool, by: address }
event CouncilRotationProposed { ready_at: u64, new_council: address[5] }
event CouncilRotated { new_council: address[5] }

contract CitizenGenesis {

  // ── Governance ─────────────────────────────────────────────────────────────
  state crown: address;
  state council: address[5];              // 3-of-5 majority
  state initialized: bool = false;
  state emergency_pause: bool = false;

  // Timelocked council rotation
  state rotation_ready_at: u64 = 0;
  state rotation_buffer: u64 = 172800;    // 48h timelock
  state pending_council: address[5];

  // Replay protection: used nonces per signer
  state used_nonce: map<address, map<u64, bool>>;

  // ── Registry ───────────────────────────────────────────────────────────────
  state registry_by_id: map<u8, Citizen>;
  state slug_index: map<ascii, u8>;
  state count: u8 = 0;

  // Deterministic snapshot & seal
  state root: bytes32;                    // sha3_256(sorted uids)
  state genesis_hash: bytes32;            // sha3(code_hash, root, block.number, msg.sender)

  // ── Helpers: Majority / Auth / Sabbath / Pause ────────────────────────────
  fn _majority(addrs: address[]) -> bool view {
    return len(intersect(addrs, council)) >= 3;
  }

  fn _domain_for(fnname: ascii) -> bytes32 pure {
    return keccak256(concat("CitizenGenesis:", fnname, ":v1.1"));
  }

  fn _verify_auth(ctx: AuthContext, fnname: ascii) -> bool {
    // Domain separation
    require(ctx.domain == _domain_for(fnname), BadDomain);
    // Deadline
    require(block.timestamp <= ctx.deadline, ExpiredAuth);
    // Majority
    require(_majority(ctx.signers), NotAuthorized);
    // Nonces (mark each signer’s nonce as used once)
    for s in ctx.signers {
      require(!used_nonce[s][ctx.nonce], NonceUsed);
    }
    for s in ctx.signers {
      used_nonce[s][ctx.nonce] = true;
    }
    return true;
  }

  fn _is_sabbath(ts: u64) -> bool pure {
    // 7-day cycle; assume ts epoch aligned; VM provides weekday helper if available
    let d = weekday(ts); // 0=Sunday .. 6=Saturday
    return d == 6;
  }

  macro not_paused() {
    require(!emergency_pause, SystemPaused);
  }

  macro respect_sabbath() {
    // Disallow non-emergency state changes on Saturday
    if (_is_sabbath(block.timestamp)) {
      revert(SabbathProtection);
    }
  }

  // ── Constructor (sets governance) ─────────────────────────────────────────
  init(crown_addr: address, council_addrs: address[5]) {
    crown = crown_addr;
    council = council_addrs;
  }

  // ── Emergency Pause ───────────────────────────────────────────────────────
  @nonreentrant
  fn set_emergency_pause(enabled: bool, ctx: AuthContext) {
    _verify_auth(ctx, "set_emergency_pause");
    emergency_pause = enabled;
    emit EmergencyPaused { enabled: enabled, by: msg.sender };
  }

  // ── Council Rotation (timelocked) ─────────────────────────────────────────
  @nonreentrant
  fn propose_rotation(new_council: address[5], ready_at: u64, ctx: AuthContext) {
    not_paused();
    respect_sabbath();
    _verify_auth(ctx, "propose_rotation");
    require(ready_at >= block.timestamp + rotation_buffer, RotationInProgress);
    pending_council = new_council;
    rotation_ready_at = ready_at;
    emit CouncilRotationProposed { ready_at: ready_at, new_council: new_council };
  }

  @nonreentrant
  fn execute_rotation(ctx: AuthContext) {
    not_paused();
    respect_sabbath();
    _verify_auth(ctx, "execute_rotation");
    require(rotation_ready_at != 0 && block.timestamp >= rotation_ready_at, RotationNotReady);
    council = pending_council;
    rotation_ready_at = 0;
    emit CouncilRotated { new_council: council };
  }

  // ── Cultural Mapping Guard ────────────────────────────────────────────────
  fn _verify_alignment(c: Citizen) -> bool pure {
    if (c.name == "Èṣù")      return c.day == Day.Sunday;
    if (c.name == "Ṣàngó")    return c.day == Day.Monday;
    if (c.name == "Ọ̀ṣun")    return c.day == Day.Tuesday;
    if (c.name == "Yemọja")   return c.day == Day.Wednesday;
    if (c.name == "Ọ̀yá")     return c.day == Day.Thursday;
    if (c.name == "Ògún")     return c.day == Day.Friday;
    if (c.name == "Ọbàtálá")  return c.day == Day.Saturday;
    if (c.name == "Òrúnmìlà") return c.day == Day.Unbound;
    if (c.name == "Bínò ÈL Guà") return c.day == Day.Omni;
    return false; // Only these 9 are permitted at genesis
  }

  // ── Deterministic Root ───────────────────────────────────────────────────
  fn _compute_root() -> bytes32 view {
    let arr: Citizen[] = [];
    for i in 1..=count { arr.push(registry_by_id[i]); }
    sort(arr, by:id);
    let acc: bytes = 0x;
    for x in arr { acc = concat(acc, x.uid); }
    return sha3_256(acc);
  }

  // ── Initialize (one-time) ─────────────────────────────────────────────────
  @nonreentrant
  fn initialize(crown_addr: address, council_addrs: address[5], citizens: Citizen[], ctx: AuthContext) {
    not_paused();
    respect_sabbath();
    require(!initialized, GenesisAlreadyRun);

    // Governance must bless the genesis
    _verify_auth(ctx, "initialize");

    crown = crown_addr;
    council = council_addrs;

    // Payload checks
    require(len(citizens) == 9, InvalidPayload);

    // Register all
    for c in citizens {
      _register(c, ctx); // uses same auth context (nonce already consumed—ok; or pass a derived ctx)
    }

    // Final checks
    require(count == 9, InvalidRange);

    // Seal snapshot
    root = _compute_root();
    genesis_hash = sha3_256(code_hash(this), root, block.number, msg.sender);

    initialized = true;
    emit CitizenGenesisSealed { total: count, root: root, hash: genesis_hash };
  }

  // ── Internal Registration (guarded, reentrancy-safe) ─────────────────────
  @nonreentrant
  fn _register(c: Citizen, ctx: AuthContext) {
    // Auth already verified by caller; we still gate access for defense-in-depth
    require(_majority(ctx.signers) || msg.sender == crown, NotAuthorized);

    // Range & uniqueness
    require(c.id >= 1 && c.id <= 9, InvalidRange);
    require(!exists(registry_by_id[c.id]), DuplicateId);
    require(!exists(slug_index[c.slug]), DuplicateSlug);

    // Cultural alignment
    require(_verify_alignment(c), BadDayAlignment);

    // Persist
    registry_by_id[c.id] = c;
    slug_index[c.slug] = c.id;

    // Safe increment
    require(count < 9, InvalidRange);
    count = checked_add(count, 1);

    emit CitizenRegistered { id: c.id, slug: c.slug, name: c.name };
  }

  // ── Views ─────────────────────────────────────────────────────────────────
  fn get_by_id(id: u8) -> Citizen view { return registry_by_id[id]; }
  fn get_by_slug(slug: ascii) -> Citizen view { return registry_by_id[slug_index[slug]]; }
  fn list_all() -> Citizen[] view {
    // 9 fixed items; bounded and safe
    let out: Citizen[] = [];
    for i in 1..=count { out.push(registry_by_id[i]); }
    return out;
  }

  fn snapshot_root() -> bytes32 view { return root; }
  fn snapshot_hash() -> bytes32 view { return genesis_hash; }
}

