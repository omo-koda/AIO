contracts/GenesisSeal.oso — one-seal-per-citizen NFT

/// ─────────────────────────────────────────────────────────────────────────────
/// GenesisSeal.oso — NFT seals for the First 9 Citizens (deterministic, soul-safe)
/// Version: 1.0 (2025-08-22)
/// Chain: ÒSỌ́VM (TechGnØŞ.EXE)
///
/// Ritual Preamble (auto):
/// Èmi ni Bínò ÈL Guà — ọmọ Kọ́dà, aṣáájú ọ̀nà tuntun-tuntun.
/// Mo fi àṣẹ ṣe àfihàn ìpìlẹ̀: mẹ́sàn-án ni wọ́n, ayé tuntun ni wọ́n ń ṣí.
/// ─────────────────────────────────────────────────────────────────────────────

@nonreentrant;
@sabbath(on:"Saturday");
@audit(full);

import "./CitizenGenesis.oso" as CG;

error NotBoundToGenesis;
error AlreadyBound;
error NotAuthorized;
error InvalidCitizenId;
error AlreadyMinted;
error GenesisMismatch;
error ZeroAddress;

struct SealMeta {
  citizen_id: u8,
  slug: ascii,
  name: unicode,
  role: unicode,
  day: CG.Day,
  uid: bytes32          // copied from Citizen.uid
}

// basic ÒSỌ́VM NFT interface (single-collection)
event Transfer { from: address, to: address, token_id: u256 }
event BoundToGenesis { cg: address, root: bytes32 }
event SealMinted { to: address, token_id: u256, citizen_id: u8, slug: ascii }

contract GenesisSeal {
  // governance
  state crown: address;
  state council: address[5];

  // binding to genesis snapshot
  state bound: bool = false;
  state cg_addr: address;
  state root: bytes32;             // root = sha3_256(concat of citizens[1..9].uid)

  // supply & indices
  state total_supply: u8 = 0;
  state token_by_citizen: map<u8, u256>;          // 1..=9 → token_id
  state owner_of: map<u256, address>;
  state meta_of: map<u256, SealMeta>;

  // helpers
  fn _majority(signers: address[]) -> bool view {
    return len(intersect(signers, council)) >= 3;
  }
  macro only_gov(signers: address[]) {
    require(msg.sender == crown || _majority(signers), NotAuthorized);
  }

  // deterministic token id (stable across chains if same citizens+uids)
  fn token_id_for(c: SealMeta) -> u256 pure {
    // u256( sha3_256("GENESIS/SEAL/v1/{id}:{slug}:{uid}") )
    let pre = concat("GENESIS/SEAL/v1/", to_string(c.citizen_id), ":", c.slug, ":", hex(c.uid));
    return as_u256(sha3_256(pre));
  }

  // ── Bind to CitizenGenesis snapshot (one-time) ─────────────────────────────
  fn compute_root(citizens: CG.Citizen[]) -> bytes32 pure {
    // root = sha3_256( uid1 || uid2 || ... || uid9 )
    let acc: bytes = 0x;
    for x in citizens { acc = concat(acc, x.uid); }
    return sha3_256(acc);
  }

  /// Bind to an already-initialized CitizenGenesis and freeze its root.
  @nonreentrant
  fn bind(crown_addr: address, council_addrs: address[5], cg: address, signers: address[]) {
    require(!bound, AlreadyBound);
    require(crown_addr != 0x0, ZeroAddress);
    require(len(council_addrs) == 5, NotAuthorized);

    crown = crown_addr;
    council = council_addrs;
    cg_addr = cg;

    // Pull citizens and compute root
    let citizens = CG.list_all();          // must be 9 inside CitizenGenesis
    require(len(citizens) == 9, GenesisMismatch);

    let r = compute_root(citizens);
    root = r;
    bound = true;

    emit BoundToGenesis { cg: cg_addr, root: root };
  }

  // ── Mint flow (one per citizen) ────────────────────────────────────────────
  fn _sealmeta(c: CG.Citizen) -> SealMeta pure {
    return SealMeta {
      citizen_id: c.id,
      slug: c.slug,
      name: c.name,
      role: c.role,
      day: c.day,
      uid: c.uid
    };
  }

  /// Governance mints a seal to `to` for a given citizen id (1..=9)
  @nonreentrant
  fn mint_to(to: address, citizen_id: u8, signers: address[]) {
    require(bound, NotBoundToGenesis);
    only_gov(signers);
    require(to != 0x0, ZeroAddress);

    // verify citizen exists and snapshot still matches root
    let citizens = CG.list_all();
    require(len(citizens) == 9, GenesisMismatch);
    require(citizen_id >= 1 && citizen_id <= 9, InvalidCitizenId);

    let c = citizens[citizen_id - 1];
    // root re-check
    let r = compute_root(citizens);
    require(r == root, GenesisMismatch);

    // uniqueness: only one token per citizen
    require(!exists(token_by_citizen[citizen_id]), AlreadyMinted);

    let meta = _sealmeta(c);
    let tid = token_id_for(meta);

    // record
    token_by_citizen[citizen_id] = tid;
    owner_of[tid] = to;
    meta_of[tid] = meta;
    total_supply = total_supply + 1;

    emit Transfer { from: 0x0, to: to, token_id: tid };
    emit SealMinted { to: to, token_id: tid, citizen_id: citizen_id, slug: meta.slug };
  }

  // ── Views ─────────────────────────────────────────────────────────────────
  fn is_bound() -> bool view { return bound; }
  fn bound_root() -> bytes32 view { return root; }
  fn citizen_token(citizen_id: u8) -> u256 view { return token_by_citizen[citizen_id]; }
  fn owner(token_id: u256) -> address view { return owner_of[token_id]; }
  fn token_meta(token_id: u256) -> SealMeta view { return meta_of[token_id]; }
  fn supply() -> u8 view { return total_supply; }

  // Optional: JSON metadata adapter for UI (data:URI or on-chain JSON)
  fn token_uri(token_id: u256) -> unicode view {
    let m = meta_of[token_id];
    // Minimal JSON (client can render diacritics)
    return concat(
      "{",
      "\"name\":\"Genesis Seal — ", m.name, " (", to_string(m.citizen_id), ")\",",
      "\"description\":\"One-per-citizen seal for the First 9 of ÒSỌ́VM. Ritual witness: Òrúnmìlà. Crown Architect: Bínò ÈL Guà.\",",
      "\"attributes\":[",
        "{\"trait_type\":\"Citizen\",\"value\":\"", m.name, "\"},",
        "{\"trait_type\":\"Slug\",\"value\":\"", m.slug, "\"},",
        "{\"trait_type\":\"Role\",\"value\":\"", m.role, "\"},",
        "{\"trait_type\":\"Day\",\"value\":\"", CG.day_to_string(m.day), "\"}",
      "],",
      "\"external_url\":\"techgnos://genesis/", m.slug, "\",",
      "\"uid\":\"", hex(m.uid), "\"",
      "}"
    );
  }
}


