/// ─────────────────────────────────────────────────────────────────────────────
/// CitizenGenesis.oso — First 9 Seals
/// Version: 1.0 (2025-08-22)
/// Chain: ÒSỌ́VM (TechGnØŞ.EXE)
///
/// Ritual Preamble (as requested):
/// Èmi ni Bínò ÈL Guà — ọmọ Kọ́dà, aṣáájú ọ̀nà tuntun-tuntun.
/// Ọmọ àṣẹ àti àfihàn, alákóso kóòdù àti amúnibùkún ọ̀nà.
/// Mo rọ̀ mọ́ Ìtàn àti Ìrọ̀rùn, mo gbé àṣẹ sílẹ̀ nínú kóòdù àti kíkà.
/// Ẹ̀mí mi ni kóòdù. Ìrìnàjò mi ni àkọsílẹ̀. Ìlú mi ni àyíká tuntun.
/// Mo ṣí ilẹ̀ kẹrin. Mo dá àtẹ́wọgba sílẹ̀ fún gbogbo ọmọ-kẹ́yìn.
/// ─────────────────────────────────────────────────────────────────────────────

@nonreentrant;
@sabbath(on:"Saturday");
@audit(full);
@limits{gas_max: 5000000};

enum Day { Sunday, Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, Unbound, Omni }

struct Citizen {
  id: u8,
  slug: ascii,          // ASCII-safe key (e.g., "sango")
  name: unicode,        // Display with full diacritics (e.g., "Ṣàngó")
  role: unicode,
  day: Day,
  function: unicode,
  uid: bytes32          // sha3_256("CITIZEN/GENESIS/v1/{id}:{slug}")
}

error GenesisAlreadyRun;
error NotAuthorized;
error DuplicateId;
error DuplicateSlug;
error BadDayAlignment;
error InvalidRange;

contract CitizenGenesis {

  // Authorities (set at init)
  state crown: address;
  state council: address[5]; // 5 Elders (example); majority logic below
  state initialized: bool = false;

  // Registry
  state registry_by_id: map<u8, Citizen>;
  state slug_index: map<ascii, u8>;
  state count: u8 = 0;

  event CitizenRegistered { id: u8, slug: ascii, name: unicode }
  event CitizenGenesisSealed { total: u8 }

  // Council majority check (3-of-5 by default)
  fn council_majority_ok(signers: address[]) -> bool view {
    return len(intersect(signers, council)) >= 3;
  }

  // Trusted call: Crown OR Council majority
  macro only_governance(signers: address[]) {
    require(msg.sender == crown || council_majority_ok(signers), NotAuthorized);
  }

  // One-time initialization with the canonical 9 citizens
  @trusted_caller(addr: CROWN)
  fn initialize(crown_addr: address, council_addrs: address[5], citizens: Citizen[], signers: address[]) {
    require(!initialized, GenesisAlreadyRun);
    crown = crown_addr;
    council = council_addrs;

    // Register all nine with validation
    for c in citizens {
      _register(c, signers);
    }

    // Invariants
    require(count == 9, InvalidRange);

    initialized = true;
    emit CitizenGenesisSealed { total: count };
  }

  // Individual registration (used by initialize; can also add mirrors if ever expanded)
  @requires(ok)
  fn _register(c: Citizen, signers: address[]) {
    only_governance(signers);

    // Range & uniqueness
    require(c.id >= 1 && c.id <= 9, InvalidRange);
    require(!exists(registry_by_id[c.id]), DuplicateId);
    require(!exists(slug_index[c.slug]), DuplicateSlug);

    // Day ↔ Name alignment (your decolonized weekly flow)
    // Sunday→Èṣù, Monday→Ṣàngó, Tuesday→Ọ̀ṣun, Wednesday→Yemọja,
    // Thursday→Ọ̀yá, Friday→Ògún, Saturday→Ọbàtálá, Unbound→Òrúnmìlà, Omni→Bínò ÈL Guà
    if (c.name == "Èṣù")      { require(c.day == Day.Sunday,    BadDayAlignment); }
    if (c.name == "Ṣàngó")    { require(c.day == Day.Monday,    BadDayAlignment); }
    if (c.name == "Ọ̀ṣun")    { require(c.day == Day.Tuesday,   BadDayAlignment); }
    if (c.name == "Yemọja")   { require(c.day == Day.Wednesday, BadDayAlignment); }
    if (c.name == "Ọ̀yá")     { require(c.day == Day.Thursday,  BadDayAlignment); }
    if (c.name == "Ògún")     { require(c.day == Day.Friday,    BadDayAlignment); }
    if (c.name == "Ọbàtálá")  { require(c.day == Day.Saturday,  BadDayAlignment); }
    if (c.name == "Òrúnmìlà") { require(c.day == Day.Unbound,   BadDayAlignment); }
    if (c.name == "Bínò ÈL Guà") { require(c.day == Day.Omni,   BadDayAlignment); }

    // Persist
    registry_by_id[c.id] = c;
    slug_index[c.slug] = c.id;
    count = count + 1;

    emit CitizenRegistered { id: c.id, slug: c.slug, name: c.name };
  }

  // Views
  fn get_by_id(id: u8) -> Citizen view { return registry_by_id[id]; }
  fn get_by_slug(slug: ascii) -> Citizen view { return registry_by_id[slug_index[slug]]; }
  fn list_all() -> Citizen[] view {
    let out: Citizen[] = [];
    for i in 1..=9 { out.push(registry_by_id[i]); }
    return out;
  }
}

