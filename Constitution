// Example policy: detect prohibited Unicode payloads; issue strike
ritual_module EmojiSmugglingPolicy {
use ImmigrationOffice as IO;
use unicode;

@constant BAN_CATEGORIES = ["Other_Symbol", "Surrogate"];

@nonreentrant
ritual inspect_and_strike(holder: address, payload: bytes) : IO.Policy {
// Normalize NFC and scan
let text = unicode.to_string(payload).normalize("NFC");
if (unicode.contains_categories(text, BAN_CATEGORIES)) {
IO.record_strike(holder, 4u8 /* content policy violation */, hash(text));
}
}
}

