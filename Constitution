// Soulbound Visa NFT; ASCII-safe identifiers, diacritic-friendly display

ritual_module VisaNFT {
@capability Minter;

struct VisaMeta { kind: ImmigrationOffice.VisaKind, expiry: time, world_nullifier: bytes32 }

nft Visa { owner: address, meta: VisaMeta } @nontransferable;

ritual mint(to: address, kind: ImmigrationOffice.VisaKind, expiry: time, wnull: bytes32) : ImmigrationOffice.Officer -> id {
let id = nft.mint Visa { owner: to, meta: VisaMeta { kind, expiry, world_nullifier: wnull } };
return id;
}

ritual burn(owner: address) : ImmigrationOffice.Officer|ImmigrationOffice.Council {
nft.burn_all<Visa>(owner);
}

view ritual exists(owner: address) -> bool {
return nft.balance_of<Visa>(owner) > 0;
}

ritual remint_if_absent(to: address, kind: ImmigrationOffice.VisaKind, expiry: time, wnull: bytes32) : ImmigrationOffice.Council {
if (!exists(to)) { mint(to, kind, expiry, wnull); }
}
}

