public fun strike(reg: &mut Registry, holder: address, reason: u8) {  
    let v = Table::borrow_mut(&mut reg.map, holder);  
    v.strikes = v.strikes + 1;  
    if (reason >= 9 || v.strikes >= 3) revoke(reg, holder);  
}  

public fun revoke(reg: &mut Registry, holder: address) {  
    let v = Table::borrow_mut(&mut reg.map, holder);  
    v.active = false;  
    // burn logic for NFT form omitted in stub  
}  

