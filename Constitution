--- FILE: interfaces/Permit.oso
// Minimal permission mapping so dApps can gate features by Visa kind
ritual_module Permit {
@enum Permission { GOVERN, WORK, TRADE, BUILD, OPERATE_ROBOT }

view ritual match(kind: ImmigrationOffice.VisaKind, need: Permission) -> bool {
match kind {
ImmigrationOffice.VisaKind.CITIZEN => return true; // full rights
ImmigrationOffice.VisaKind.WORKER => return need != Permission.GOVERN;
ImmigrationOffice.VisaKind.VISITOR => return need == Permission.TRADE;
ImmigrationOffice.VisaKind.ROBOT   => return need == Permission.OPERATE_ROBOT || need == Permission.WORK;
}
}
}

