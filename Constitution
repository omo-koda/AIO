// ÒSỌ́ Language module — Visa issuance, strikes, revocation, appeal, propagation

ritual_module ImmigrationOffice {
/// 🕯️ Ritual Declaration
/// Èmi ni Bínò ÈL Guà — ọmọ Kọ́dà, aṣáájú ọ̀nà tuntun-tuntun.
/// Module: "Ìbùdó Ìbìwọlé" (Immigration Office)
/// Purpose: Bind access to sacred economy/governance via World ID + Visa covenant.

use VisaNFT as Visa;
use BlacklistSBT as Blacklist;
use Permit;
use world_id;         // zk verification oracle (stub interface)
use council;          // Crown/Council multisig
use time;

@constant MAX_STRIKES: u8 = 3;
@constant SEVERE: u8 = 9; // reasonCode ≥ 9 triggers instant revoke

@capability Admin;
@capability Officer extends Admin; // may issue/renew
@capability Policy;               // may record strikes
@capability Oracle;               // world_id attesters
@capability Council;              // appeal + emergency

@event VisaIssued { holder: address, world_nullifier: bytes32, visa_id: id, kind: VisaKind, expiry: time }
@event StrikeRecorded { holder: address, reason_code: u8, evidence: bytes32, total_strikes: u8 }
@event VisaRevoked { holder: address, world_nullifier: bytes32, reason_code: u8, blacklist_tx: id }
@event RevocationBroadcast { world_nullifier: bytes32, holder: address, reason_code: u8, ts: time }
@event AppealOpened { holder: address, case_id: id }
@event AppealResolved { holder: address, case_id: id, outcome: AppealOutcome }
@event EmergencyToggle { enabled: bool, actor: address }

@error AlreadyHasVisa;
@error InvalidWorldID;
@error NoActiveVisa;
@error NotBlacklisted;
@error SabbathProtection;
@error OnlySevereDirectRevoke;

@enum VisaKind { CITIZEN, WORKER, VISITOR, ROBOT }
@enum Status { NONE, ACTIVE, SUSPENDED, REVOKED }
@enum AppealOutcome { Uphold, Reinstate }

struct VisaRecord {
holder: address,
world_nullifier: bytes32,  // World ID nullifier commitment
kind: VisaKind,
status: Status,
strikes: u8,
expiry: time,
created_at: time,
revoked_at: time,
}

storage registry: map<address, VisaRecord>;
storage byWorld: map<bytes32, address>;      // world_nullifier → holder
storage blacklist: set<bytes32>;             // world_nullifier set
storage emergency_pause: bool = false;

// 🔒 Sabbath guard (Emergency‑Flexible Sabbath)
macro respect_sabbath() {
if (time.is_sabbath(time.now()) && !emergency_pause) {
revert(SabbathProtection);
}
}

// Crown/Council may toggle emergency to permit actions during Sabbath
@nonreentrant @sabbath(on:"Saturday")
ritual set_emergency(on: bool) : Council {
emergency_pause = on;
emit EmergencyToggle { enabled: on, actor: tx.caller };
}

// ✅ Issue a new Visa — requires valid World ID proof bound to holder
@nonreentrant
ritual issue_visa(holder: address,
proof: world_id.Proof,
kind: VisaKind,
expiry: time) : Officer {
respect_sabbath();

let signal = hash(holder);  
if (!world_id.verify(proof, signal)) { revert(InvalidWorldID); }  

let wnull = proof.nullifier;  
if (byWorld.contains(wnull)) { revert(AlreadyHasVisa); }  

// Mint soulbound Visa NFT to holder  
let visa_id = Visa.mint(holder, kind, expiry, wnull);  

let rec = VisaRecord {  
  holder, world_nullifier: wnull, kind,  
  status: Status.ACTIVE,  
  strikes: 0u8,  
  expiry,  
  created_at: time.now(),  
  revoked_at: 0  
};  

registry[holder] = rec;  
byWorld[wnull] = holder;  

emit VisaIssued { holder, world_nullifier: wnull, visa_id, kind, expiry };

}

// ➕ Record a strike from a policy module
@nonreentrant
ritual record_strike(holder: address, reason_code: u8, evidence: bytes32) : Policy {
respect_sabbath();

if (!registry.contains(holder) || registry[holder].status != Status.ACTIVE) { revert(NoActiveVisa); }  

let rec = registry[holder];  
rec.strikes = rec.strikes + 1u8;  
registry[holder] = rec;  

emit StrikeRecorded { holder, reason_code, evidence, total_strikes: rec.strikes };  

if (reason_code >= SEVERE || rec.strikes >= MAX_STRIKES) {  
  _revoke(holder, reason_code);  
}

}

// ⛔ Direct revoke (severe only) by Officer/Council
@nonreentrant
ritual revoke_now(holder: address, reason_code: u8) : Officer|Council {
respect_sabbath();
if (reason_code < SEVERE) { revert(OnlySevereDirectRevoke); }
_revoke(holder, reason_code);
}

// ♻️ Renew (extends expiry, resets strikes optionally)
@nonreentrant
ritual renew(holder: address, new_expiry: time, reset_strikes: bool=false) : Officer {
respect_sabbath();
if (!registry.contains(holder) || registry[holder].status != Status.ACTIVE) { revert(NoActiveVisa); }
let rec = registry[holder];
rec.expiry = new_expiry;
if (reset_strikes) { rec.strikes = 0u8; }
registry[holder] = rec;
}

// 🔍 Permission check for ecosystem modules
view ritual is_permitted(subject: address, need: Permit.Permission) -> bool {
if (!registry.contains(subject)) return false;
let rec = registry[subject];
if (rec.status != Status.ACTIVE) return false;
if (time.now() > rec.expiry) return false;
return Permit.match(rec.kind, need);
}

// 🏛️ Appeal flow
@nonreentrant
ritual open_appeal(holder: address) : Admin {
respect_sabbath();
let case_id = hash(holder, time.now());
emit AppealOpened { holder, case_id };
}

@nonreentrant
ritual resolve_appeal(holder: address, case_id: id, outcome: AppealOutcome) : Council {
respect_sabbath();
match outcome {
AppealOutcome.Reinstate => {
if (!registry.contains(holder)) { return; }
let rec = registry[holder];
if (rec.status == Status.REVOKED) {
// Remove from blacklist and re-mint Visa if needed
blacklist.remove(rec.world_nullifier);
Blacklist.burn_if_present(holder);
Visa.remint_if_absent(holder, rec.kind, rec.expiry, rec.world_nullifier);
rec.status = Status.ACTIVE;
rec.revoked_at = 0;
registry[holder] = rec;
}
}
_ => { /* Uphold: do nothing */ }
}
emit AppealResolved { holder, case_id, outcome };
}

// --- Internals ---
fn _revoke(holder: address, reason_code: u8) {
if (!registry.contains(holder)) { return; }
let rec = registry[holder];
if (rec.status == Status.REVOKED) { return; }

// Burn Visa, issue Blacklist SBT  
Visa.burn(holder);  
let bl_id = Blacklist.mint(holder, rec.world_nullifier, reason_code);  

rec.status = Status.REVOKED;  
rec.revoked_at = time.now();  
registry[holder] = rec;  
blacklist.insert(rec.world_nullifier);  

emit VisaRevoked { holder, world_nullifier: rec.world_nullifier, reason_code, blacklist_tx: bl_id };  
emit RevocationBroadcast { world_nullifier: rec.world_nullifier, holder, reason_code, ts: time.now() };

}
}

